@page "/"
@using AgentCompanyWeb.Data
@using AgentCompanyWeb.Data.Models
@using AgentCompanyWeb.Services
@using AgentCompanyWeb.Components.Shared
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.SignalR.Client
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Nav
@inject ToastService Toast
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>Command Center - Agent Company</PageTitle>

<!-- Status Strip - Persistent top bar -->
<StatusStrip />

<div class="command-center">
    <!-- Top Row: Overview Panels -->
    <div class="dashboard-row dashboard-row-top">
        <div class="panel panel-swarm">
            <SwarmMiniMap />
        </div>
        <div class="panel panel-work">
            <ActiveWorkPanel />
        </div>
        <div class="panel panel-alerts">
            <AlertsSummary />
        </div>
    </div>

    <!-- Main Content Row -->
    <div class="dashboard-row dashboard-row-main">
        <!-- Activity Timeline - Left side -->
        <div class="panel panel-timeline">
            <ActivityTimeline MaxItems="100" />
        </div>

        <!-- Stats and Quick Actions - Right side -->
        <div class="dashboard-sidebar">
            <!-- Quick Stats -->
            <div class="quick-stats">
                <div class="stat-item" @onclick="GoToAgents" style="cursor: pointer;">
                    <div class="stat-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                    </div>
                    <div class="stat-content">
                        <div class="stat-value">@_totalAgents</div>
                        <div class="stat-label">Total Agents</div>
                    </div>
                </div>
                <div class="stat-item" @onclick="GoToGroups" style="cursor: pointer;">
                    <div class="stat-icon groups">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                        </svg>
                    </div>
                    <div class="stat-content">
                        <div class="stat-value">@_totalGroups</div>
                        <div class="stat-label">Groups</div>
                    </div>
                </div>
                <div class="stat-item" @onclick="GoToMessages" style="cursor: pointer;">
                    <div class="stat-icon messages">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                        </svg>
                    </div>
                    <div class="stat-content">
                        <div class="stat-value">@_totalMessages</div>
                        <div class="stat-label">Messages Today</div>
                    </div>
                </div>
                <div class="stat-item" @onclick="GoToSchedules" style="cursor: pointer;">
                    <div class="stat-icon schedules">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <polyline points="12 6 12 12 16 14"></polyline>
                        </svg>
                    </div>
                    <div class="stat-content">
                        <div class="stat-value">@_activeSchedules</div>
                        <div class="stat-label">Active Schedules</div>
                    </div>
                </div>
            </div>

            <!-- Recent Agents -->
            <div class="recent-agents-panel">
                <div class="panel-header">
                    <h3>Recent Agents</h3>
                    <button class="btn-link" @onclick="GoToAgents">View All</button>
                </div>
                <div class="recent-agents-list">
                    @if (_recentAgents.Count == 0)
                    {
                        <div class="empty-recent">
                            <span>No agents yet</span>
                        </div>
                    }
                    else
                    {
                        @foreach (var agent in _recentAgents)
                        {
                            <div class="recent-agent-item" @onclick="() => OpenAgent(agent.Id)">
                                <span class="status-dot @GetStatusClass(agent.Status)"></span>
                                <div class="agent-info">
                                    <span class="agent-name">@agent.Name</span>
                                    @if (!string.IsNullOrEmpty(agent.Role))
                                    {
                                        <span class="agent-role">@agent.Role</span>
                                    }
                                </div>
                                <span class="agent-group-dot @GetGroupColorClass(agent.Group?.Color)"></span>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Floating Assign Task Button -->
    <button class="assign-task-fab" @onclick="OpenAssignModal">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="22" y1="2" x2="11" y2="13"></line>
            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
        <span>Assign Task</span>
    </button>
</div>

<!-- Task Assignment Modal -->
<TaskAssignModal IsOpen="_showAssignModal" OnClose="CloseAssignModal" OnTaskAssigned="HandleTaskAssigned" />

<style>
    .command-center {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 60px); /* Account for status strip */
        padding: 20px 24px;
        gap: 20px;
        overflow: hidden;
    }

    .dashboard-row {
        display: flex;
        gap: 20px;
    }

    .dashboard-row-top {
        flex-shrink: 0;
    }

    .dashboard-row-top .panel {
        flex: 1;
        min-width: 0;
    }

    .dashboard-row-main {
        flex: 1;
        min-height: 0;
        overflow: hidden;
    }

    .panel-timeline {
        flex: 2;
        min-width: 0;
    }

    .dashboard-sidebar {
        flex: 1;
        min-width: 280px;
        max-width: 360px;
        display: flex;
        flex-direction: column;
        gap: 20px;
        overflow: hidden;
    }

    .dashboard-row-bottom {
        flex-shrink: 0;
    }

    /* Quick Stats */
    .quick-stats {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
    }

    .stat-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px;
        background: var(--bg-card);
        border: 1px solid var(--border-light);
        border-radius: var(--radius-lg);
        transition: all 0.15s ease;
    }

    .stat-item:hover {
        border-color: var(--accent);
        box-shadow: var(--shadow-sm);
    }

    .stat-icon {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bg-active);
        border-radius: var(--radius-md);
        color: var(--accent);
    }

    .stat-icon.groups { background: rgba(88, 86, 214, 0.1); color: #5856D6; }
    .stat-icon.messages { background: rgba(52, 199, 89, 0.1); color: var(--success); }
    .stat-icon.schedules { background: rgba(255, 159, 10, 0.1); color: var(--warning); }

    .stat-content {
        flex: 1;
        min-width: 0;
    }

    .stat-value {
        font-size: 20px;
        font-weight: 600;
        color: var(--text-primary);
        line-height: 1.2;
    }

    .stat-label {
        font-size: 11px;
        color: var(--text-tertiary);
        margin-top: 2px;
    }

    /* Recent Agents Panel */
    .recent-agents-panel {
        background: var(--bg-card);
        border: 1px solid var(--border-light);
        border-radius: var(--radius-lg);
        overflow: hidden;
        flex: 1;
        min-height: 0;
        display: flex;
        flex-direction: column;
    }

    .recent-agents-panel .panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 16px;
        border-bottom: 1px solid var(--border-light);
        flex-shrink: 0;
    }

    .recent-agents-panel .panel-header h3 {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-primary);
        margin: 0;
    }

    .btn-link {
        background: none;
        border: none;
        color: var(--accent);
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
    }

    .btn-link:hover {
        text-decoration: underline;
    }

    .recent-agents-list {
        flex: 1;
        overflow-y: auto;
        padding: 8px;
    }

    .empty-recent {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        color: var(--text-tertiary);
        font-size: 13px;
    }

    .recent-agent-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        border-radius: var(--radius-md);
        cursor: pointer;
        transition: background 0.15s ease;
    }

    .recent-agent-item:hover {
        background: var(--bg-hover);
    }

    .recent-agent-item .agent-info {
        flex: 1;
        min-width: 0;
    }

    .recent-agent-item .agent-name {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: var(--text-primary);
    }

    .recent-agent-item .agent-role {
        display: block;
        font-size: 11px;
        color: var(--text-tertiary);
    }

    .agent-group-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    /* Group color classes */
    .group-blue { background: #0071E3; }
    .group-purple { background: #5856D6; }
    .group-pink { background: #FF2D55; }
    .group-orange { background: #FF9500; }
    .group-green { background: #34C759; }
    .group-teal { background: #5AC8FA; }

    /* Floating Assign Task Button */
    .assign-task-fab {
        position: fixed;
        bottom: 24px;
        right: 24px;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px 24px;
        background: var(--accent);
        border: none;
        border-radius: var(--radius-full);
        color: white;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 4px 16px rgba(0, 113, 227, 0.3);
        transition: all 0.2s ease;
        z-index: 100;
    }

    .assign-task-fab:hover {
        background: var(--accent-hover);
        transform: translateY(-2px);
        box-shadow: 0 6px 24px rgba(0, 113, 227, 0.4);
    }

    .assign-task-fab:active {
        transform: translateY(0);
    }
</style>

@code {
    private List<Agent> _recentAgents = new();
    private int _totalAgents = 0;
    private int _totalGroups = 0;
    private int _totalMessages = 0;
    private int _activeSchedules = 0;
    private HubConnection? _hubConnection;
    private bool _showAssignModal = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        await ConnectToSignalR();
    }

    private async Task ConnectToSignalR()
    {
        try
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl(Nav.ToAbsoluteUri("/hubs/agentnetwork"))
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<dynamic>("AgentStatusChanged", async (status) =>
            {
                await InvokeAsync(async () =>
                {
                    await LoadData();
                    StateHasChanged();
                });
            });

            await _hubConnection.StartAsync();
        }
        catch { }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection != null)
        {
            await _hubConnection.DisposeAsync();
        }
    }

    private async Task LoadData()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        _recentAgents = await db.Agents
            .Include(a => a.Group)
            .OrderByDescending(a => a.LastActivityAt)
            .Take(6)
            .ToListAsync();

        _totalAgents = await db.Agents.CountAsync();
        _totalGroups = await db.Groups.CountAsync();

        // Count today's messages
        var today = DateTime.UtcNow.Date;
        _totalMessages = await db.NetworkMessages
            .CountAsync(m => m.Timestamp >= today);

        // Count active schedules
        _activeSchedules = await db.CronJobs.CountAsync(c => c.Enabled);
    }

    private void OpenAssignModal() => _showAssignModal = true;
    private void CloseAssignModal() => _showAssignModal = false;

    private async Task HandleTaskAssigned((List<Agent> agents, string task, string priority) assignment)
    {
        // TODO: Implement actual task assignment via Agent Network
        // For now, this updates the task field and shows a notification
        await using var db = await DbFactory.CreateDbContextAsync();

        foreach (var agent in assignment.agents)
        {
            var dbAgent = await db.Agents.FindAsync(agent.Id);
            if (dbAgent != null)
            {
                dbAgent.CurrentTask = assignment.task;
                dbAgent.Status = AgentStatus.Working;
                dbAgent.LastActivityAt = DateTime.UtcNow;
            }
        }

        await db.SaveChangesAsync();
        await LoadData();
        StateHasChanged();
    }

    private void GoToAgents() => Nav.NavigateTo("/agents");
    private void GoToGroups() => Nav.NavigateTo("/groups");
    private void GoToMessages() => Nav.NavigateTo("/messages");
    private void GoToSchedules() => Nav.NavigateTo("/schedules");
    private void OpenAgent(int agentId) => Nav.NavigateTo($"/agent/{agentId}");

    private string GetStatusClass(AgentStatus status) => status switch
    {
        AgentStatus.Online => "status-online",
        AgentStatus.Working => "status-working",
        AgentStatus.Starting => "status-starting",
        AgentStatus.Error => "status-error",
        _ => "status-offline"
    };

    private string GetGroupColorClass(string? color) => color switch
    {
        "blue" => "group-blue",
        "purple" => "group-purple",
        "pink" => "group-pink",
        "orange" => "group-orange",
        "green" => "group-green",
        "teal" => "group-teal",
        _ => "group-blue"
    };
}
