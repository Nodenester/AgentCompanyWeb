        _teams = await teamsQuery.ToListAsync();
        _cronJobs = await db.CronJobs.Where(c => c.Enabled).ToListAsync();

        // Build connections
        _connections.Clear();
        foreach (var agent in _agents)
        {
            foreach (var membership in agent.TeamMemberships)
            {
