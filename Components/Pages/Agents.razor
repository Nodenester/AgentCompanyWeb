    private async Task LoadData()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        _groups = await db.Groups.ToListAsync();

        IQueryable<Agent> agentsQuery = db.Agents.Include(a => a.Group).Include(a => a.TeamMemberships);
        IQueryable<Team> teamsQuery = db.Teams.Include(t => t.Members).Include(t => t.Group);

