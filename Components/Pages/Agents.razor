    private async Task SaveAgent()
    {
        if (_selectedAgent == null || string.IsNullOrWhiteSpace(_selectedAgent.Name))
            return;

        var isNew = _selectedAgent.Id == 0;

        await using var db = await DbFactory.CreateDbContextAsync();

        if (isNew)
        {
            db.Agents.Add(_selectedAgent);
        }
        else
        {
            db.Agents.Update(_selectedAgent);
        }

        await db.SaveChangesAsync();

        // If it's a new agent, auto-start and navigate to detail page
        if (isNew)
        {
            var agentId = _selectedAgent.Id;
            try
            {
                // Get all credentials from the agent's group
                var credentials = await GroupService.GetAllCredentialsAsync(_selectedAgent.GroupId);

                // Create the Docker container
                _selectedAgent.Status = AgentStatus.Starting;
                db.Agents.Update(_selectedAgent);
                await db.SaveChangesAsync();

                var dockerAgent = await DockerAgentService.CreateAgentAsync(_selectedAgent.Name, credentials);

                // Update our database agent with the container info
                _selectedAgent.ContainerId = dockerAgent.ContainerId;
                _selectedAgent.VncUrl = dockerAgent.VncUrl;
                db.Agents.Update(_selectedAgent);
                await db.SaveChangesAsync();
            }
            catch
            {
                // If auto-start fails, still navigate to detail page where user can manually start
                _selectedAgent.Status = AgentStatus.Offline;
                db.Agents.Update(_selectedAgent);
                await db.SaveChangesAsync();
            }

            ClosePanel();
            Nav.NavigateTo($"/agent/{agentId}");
            return;
        }

        await LoadData();
        ClosePanel();
    }

    private async Task DeleteAgent()
