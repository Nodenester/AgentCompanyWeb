    private async Task ToggleTeamMember(int agentId, bool shouldBeMember)
    {
        if (_selectedTeam?.Id == 0) return;

        var teamId = _selectedTeam!.Id;
        var teamName = _selectedTeam.Name;

        await using var db = await DbFactory.CreateDbContextAsync();

        var existing = await db.TeamMembers
            .FirstOrDefaultAsync(tm => tm.AgentId == agentId && tm.TeamId == teamId);

        if (shouldBeMember && existing == null)
        {
            var membership = new TeamMember
            {
                AgentId = agentId,
                TeamId = teamId
            };
            db.TeamMembers.Add(membership);
            await db.SaveChangesAsync();

            // Notify daemon to join the group
            var agent = await db.Agents.FindAsync(agentId);
            if (agent != null)
            {
                try
                {
                    var dockerAgent = DockerAgentService.GetAgents()
                        .FirstOrDefault(a => a.Name == agent.Name);
                    if (dockerAgent != null)
                    {
                        await DockerAgentService.JoinAgentToGroupAsync(dockerAgent.Id, teamName);
                    }
                }
                catch { /* Agent may not be running */ }
            }
        }
        else if (!shouldBeMember && existing != null)
        {
            db.TeamMembers.Remove(existing);
            await db.SaveChangesAsync();

            // Notify daemon to leave the group
            var agent = await db.Agents.FindAsync(agentId);
            if (agent != null)
            {
                try
                {
                    var dockerAgent = DockerAgentService.GetAgents()
                        .FirstOrDefault(a => a.Name == agent.Name);
                    if (dockerAgent != null)
                    {
                        await DockerAgentService.RemoveAgentFromGroupAsync(dockerAgent.Id, teamName);
                    }
                }
                catch { /* Agent may not be running */ }
            }
        }

        // Reload the team with updated members
        _selectedTeam = await db.Teams
            .Include(t => t.Members)
            .Include(t => t.Group)
            .FirstOrDefaultAsync(t => t.Id == teamId);

        await LoadData();
        StateHasChanged();
    }

    private void StartDrag(MouseEventArgs e, Agent? agent, Team? team)
    {
        // Cancel any panning
        _isPanning = false;

        // Store initial mouse position FIRST
        _dragStartMouseX = e.ClientX;
        _dragStartMouseY = e.ClientY;
        _lastMouseX = e.ClientX;
        _lastMouseY = e.ClientY;

        // Store initial node position BEFORE setting dragging state
        if (agent != null)
        {
            _dragStartNodeX = agent.CanvasX;
            _dragStartNodeY = agent.CanvasY;
        }
        else if (team != null)
        {
            _dragStartNodeX = team.CanvasX;
            _dragStartNodeY = team.CanvasY;
        }
        else
        {
            // Safety: don't start drag if no target
            return;
        }

        // Now set the dragging state
        _draggingAgent = agent;
        _draggingTeam = team;
        _hasMoved = false;
        _isDragging = true;
    }

    private async Task OnCanvasMouseEnter(MouseEventArgs e)
    {
        // Update cached container rect when mouse enters
        try
        {
            var rect = await JS.InvokeAsync<ContainerRect>("canvasInterop.getContainerRect");
            if (rect != null)
            {
                _containerLeft = rect.Left;
                _containerTop = rect.Top;
            }
        }
        catch
        {
            // Ignore errors
        }
    }

    private void OnCanvasWheel(WheelEventArgs e)
    {
        var oldZoom = _zoom;

        if (e.DeltaY < 0)
        {
            // Scroll up = zoom in
            _zoom = Math.Min(ZoomMax, _zoom + ZoomStep);
        }
        else
        {
            // Scroll down = zoom out
            _zoom = Math.Max(ZoomMin, _zoom - ZoomStep);
        }

        // If zoom didn't change, nothing to do
        if (Math.Abs(oldZoom - _zoom) < 0.001) return;

        // Calculate mouse position relative to container using cached rect
        // e.ClientX/Y is viewport-relative, subtract container position
        var mouseX = e.ClientX - _containerLeft;
        var mouseY = e.ClientY - _containerTop;

        // Calculate the canvas point under the mouse BEFORE zoom change
        // screenPos = panPos + canvasPos * zoom
        // canvasPos = (screenPos - panPos) / oldZoom
        var canvasX = (mouseX - _panX) / oldZoom;
        var canvasY = (mouseY - _panY) / oldZoom;

        // After zoom, we want that same canvas point to still be under the mouse
        // mouseX = newPanX + canvasX * newZoom
        // newPanX = mouseX - canvasX * newZoom
        _panX = mouseX - canvasX * _zoom;
        _panY = mouseY - canvasY * _zoom;

        StateHasChanged();
    }

    private void ZoomIn()
    {
        _zoom = Math.Min(ZoomMax, _zoom + ZoomStep);
        StateHasChanged();
    }

    private void ZoomOut()
    {
        _zoom = Math.Max(ZoomMin, _zoom - ZoomStep);
        StateHasChanged();
    }

    private void ResetZoom()
    {
        _zoom = 1.0;
        _panX = 0;
        _panY = 0;
        StateHasChanged();
    }

    private void StartPan(MouseEventArgs e)
    {
        // Only start panning if not already dragging a node
        if (!_isDragging && _draggingAgent == null && _draggingTeam == null)
        {
            _isPanning = true;
            _lastMouseX = e.ClientX;
            _lastMouseY = e.ClientY;
        }
    }

    private async Task OnCanvasMouseMove(MouseEventArgs e)
    {
        var deltaX = e.ClientX - _lastMouseX;
        var deltaY = e.ClientY - _lastMouseY;
        _lastMouseX = e.ClientX;
        _lastMouseY = e.ClientY;

        // Handle panning
        if (_isPanning)
        {
            _panX += deltaX;
            _panY += deltaY;
            StateHasChanged();
            return;
        }

        // Must have valid drag state
        if (!_isDragging || (_draggingAgent == null && _draggingTeam == null)) return;

        // Safety check: ensure dragged item is still in the list
        // (protects against LoadData being called during drag which creates new list instances)
        if (_draggingAgent != null && !_agents.Contains(_draggingAgent))
        {
            var match = _agents.FirstOrDefault(a => a.Id == _draggingAgent.Id);
            if (match != null)
            {
                _draggingAgent = match;
                _dragStartNodeX = match.CanvasX;
                _dragStartNodeY = match.CanvasY;
            }
            else
            {
                _isDragging = false;
                _draggingAgent = null;
                return;
            }
        }
        if (_draggingTeam != null && !_teams.Contains(_draggingTeam))
        {
            var match = _teams.FirstOrDefault(t => t.Id == _draggingTeam.Id);
            if (match != null)
            {
                _draggingTeam = match;
                _dragStartNodeX = match.CanvasX;
                _dragStartNodeY = match.CanvasY;
            }
            else
            {
                _isDragging = false;
                _draggingTeam = null;
                return;
            }
        }

        // Calculate total movement from drag start
        var totalDeltaX = e.ClientX - _dragStartMouseX;
        var totalDeltaY = e.ClientY - _dragStartMouseY;

        // Check if we've moved past the threshold to consider it a drag
        if (Math.Abs(totalDeltaX) > DragThreshold || Math.Abs(totalDeltaY) > DragThreshold)
        {
            _hasMoved = true;
        }

        // Use absolute positioning: initial position + total mouse delta (scaled by zoom)
        var newX = _dragStartNodeX + (totalDeltaX / _zoom);
        var newY = _dragStartNodeY + (totalDeltaY / _zoom);

        if (_draggingAgent != null)
        {
            _draggingAgent.CanvasX = newX;
            _draggingAgent.CanvasY = newY;
            UpdateConnections();
        }
        else if (_draggingTeam != null)
        {
            _draggingTeam.CanvasX = newX;
            _draggingTeam.CanvasY = newY;
            UpdateConnections();
        }

        StateHasChanged();
    }

    private async Task OnCanvasMouseUp(MouseEventArgs e)
    {
        // Reset panning state
        _isPanning = false;

        if (_isDragging)
        {
            var wasAgent = _draggingAgent;
            var wasTeam = _draggingTeam;
            var didMove = _hasMoved;

            // Save positions to database only if we actually moved
            if (didMove)
            {
                await using var db = await DbFactory.CreateDbContextAsync();
                if (_draggingAgent != null)
                {
                    db.Agents.Update(_draggingAgent);
                    await db.SaveChangesAsync();
                }
                else if (_draggingTeam != null)
                {
                    db.Teams.Update(_draggingTeam);
                    await db.SaveChangesAsync();
                }
            }

            // Reset drag state first
            _isDragging = false;
            _hasMoved = false;
            _draggingAgent = null;
            _draggingTeam = null;

            // If we didn't drag (just clicked), open the edit panel or handle connection
            // But not if we clicked the connector button
            if (!didMove && !_isConnectorClick)
            {
                if (wasAgent != null)
                {
                    SelectAgent(wasAgent);
                }
                else if (wasTeam != null)
                {
                    await OnTeamClicked(wasTeam);
                }
            }

            _isConnectorClick = false; // Reset the flag
        }
    }

    private void UpdateConnections()
    {
        _connections.Clear();
        foreach (var agent in _agents)
        {
            foreach (var membership in agent.TeamMemberships)
            {
                var team = _teams.FirstOrDefault(t => t.Id == membership.TeamId);
                if (team != null)
                {
                    _connections.Add(new Connection
                    {
                        FromX = agent.CanvasX,
                        FromY = agent.CanvasY,
                        ToX = team.CanvasX,
                        ToY = team.CanvasY,
                        Color = team.Color
                    });
                }
            }
        }
    }

    private bool _isConnectorClick = false;

    private void StartConnecting(Agent agent)
    {
        _isConnectorClick = true; // Flag to prevent side panel from opening

        if (_connectingFromAgent?.Id == agent.Id)
        {
            // Cancel if clicking same agent
            _connectingFromAgent = null;
        }
        else
        {
            _connectingFromAgent = agent;
        }
    }

    private async Task OnTeamClicked(Team team)
    {
        if (_connectingFromAgent != null)
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            // Connect agent to team
            var existing = await db.TeamMembers
                .FirstOrDefaultAsync(tm => tm.AgentId == _connectingFromAgent.Id && tm.TeamId == team.Id);

            if (existing == null)
            {
                var membership = new TeamMember
                {
                    AgentId = _connectingFromAgent.Id,
                    TeamId = team.Id
                };
                db.TeamMembers.Add(membership);
                await db.SaveChangesAsync();

                // Create Agent Network group for the team (if connected)
                try
                {
                    if (!AgentNetwork.IsConnected)
                    {
                        await AgentNetwork.ConnectAsync("AgentCompanyWeb");
                    }

                    // Create group for this team (idempotent - won't fail if exists)
                    await AgentNetwork.CreateGroupAsync(team.Name);

                    // Tell the agent to join this group (via Redis command)
                    // Find the Docker agent by name to get its ID
                    var dockerAgent = DockerAgentService.GetAgents()
                        .FirstOrDefault(a => a.Name == _connectingFromAgent.Name);
                    if (dockerAgent != null)
                    {
                        await DockerAgentService.JoinAgentToGroupAsync(dockerAgent.Id, team.Name);
                    }

                    // Send a welcome message to the group
                    await AgentNetwork.SendGroupMessageAsync(team.Name,
                        $"Agent {_connectingFromAgent.Name} has joined the team!");
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Agent Network integration error: {ex.Message}");
                }

                await LoadData();
            }

            _connectingFromAgent = null;
        }
        else
        {
            // Open team panel
            SelectTeam(team);
        }
    }

