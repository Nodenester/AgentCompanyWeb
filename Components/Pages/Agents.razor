    private async Task DeleteTeam()
    {
        if (_selectedTeam?.Id > 0)
        {
            var teamName = _selectedTeam.Name;
            var teamId = _selectedTeam.Id;

            await using var db = await DbFactory.CreateDbContextAsync();

            // Delete team members first
            var memberships = await db.TeamMembers
                .Where(tm => tm.TeamId == teamId)
                .ToListAsync();
            db.TeamMembers.RemoveRange(memberships);

            // Delete network group and its messages
            var networkGroup = await db.NetworkGroups
                .FirstOrDefaultAsync(g => g.Name == teamName);
            if (networkGroup != null)
            {
                // Delete messages in this group
                var messages = await db.NetworkMessages
                    .Where(m => m.GroupName == teamName)
                    .ToListAsync();
                db.NetworkMessages.RemoveRange(messages);
