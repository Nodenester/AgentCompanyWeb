                Console.WriteLine($"Failed to disconnect from network: {ex.Message}");
            }

            // Find and remove Docker container by agent name
            try
            {
                var dockerAgent = DockerAgentService.GetAgents()
                    .FirstOrDefault(a => a.Name == agentName);
                if (dockerAgent != null)
                {
                    await DockerAgentService.RemoveAgentAsync(dockerAgent.Id);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Failed to remove container: {ex.Message}");
                // Continue with database deletion even if container removal fails
            }

            await using var db = await DbFactory.CreateDbContextAsync();

            // Remove network connection record
            try
            {
                var networkConn = await db.NetworkConnections
                    .FirstOrDefaultAsync(nc => nc.AgentName == agentName);
                if (networkConn != null)
                {
                    db.NetworkConnections.Remove(networkConn);
                }
            }
            catch { }

            // Remove from any teams first
            var memberships = await db.TeamMembers
                .Where(tm => tm.AgentId == agentId)
                .ToListAsync();
            db.TeamMembers.RemoveRange(memberships);

            // Need to re-fetch the agent from the new context
            var agentToDelete = await db.Agents.FindAsync(agentId);
            if (agentToDelete != null)
            {
                db.Agents.Remove(agentToDelete);
            }
            await db.SaveChangesAsync();
            await LoadData();
        }
        ClosePanel();
    }

