    private double GetCronJobX(CronJob job)
    {
        if (job.TargetAgentId.HasValue)
        {
            var agent = _agents.FirstOrDefault(a => a.Id == job.TargetAgentId);
            if (agent != null)
                return agent.CanvasX - 80;
        }
        var index = _cronJobs.IndexOf(job);
        return 50 + (index % 3) * 100;
    }

    private double GetCronJobY(CronJob job)
    {
        if (job.TargetAgentId.HasValue)
        {
            var agent = _agents.FirstOrDefault(a => a.Id == job.TargetAgentId);
            if (agent != null)
                return agent.CanvasY - 30;
        }
        var index = _cronJobs.IndexOf(job);
        return 50 + (index / 3) * 60;
    }

    private string GetScheduleDescription(CronJob job) => job.ScheduleType switch
    {
        ScheduleType.Interval => $"Every {job.IntervalMinutes}m",
        ScheduleType.Daily => $"Daily {job.TimeOfDay}",
        ScheduleType.Weekly => $"Weekly {job.TimeOfDay}",
        ScheduleType.Monthly => $"Monthly day {job.DayOfMonth}",
        ScheduleType.Cron => job.CronExpression ?? "Custom",
        ScheduleType.OneTime => "Once",
        _ => "Unknown"
    };

    private class Connection
    {
        public double FromX { get; set; }
        public double FromY { get; set; }
        public double ToX { get; set; }
        public double ToY { get; set; }
        public string Color { get; set; } = "blue";
    }

    private class ContainerRect
    {
        public double Left { get; set; }
        public double Top { get; set; }
        public double Width { get; set; }
        public double Height { get; set; }
    }
}
