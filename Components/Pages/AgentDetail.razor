@code {
    [Parameter]
    public int AgentId { get; set; }

    private AgentCompanyWeb.Data.Models.Agent? _agent;
    private AgentCompanyEngineer.Models.Agent? _dockerAgent;
    private List<WorkspaceItem> _workspaces = new();
    private List<ChatMessage> _messages = new();
    private string _viewMode = "chat";
    private string _taskInput = "";
    private bool _isAgentThinking = false;
    private bool _showAddWorkspace = false;
    private string _newWorkspaceName = "";
    private string _newWorkspaceUrl = "";
    private string _newWorkspaceBranch = "main";
    private ElementReference _messagesRef;
    private bool _redisConnected = false;
    private bool _signalRConnected = false;
    private bool _isStarting = false;
    private Action<AgentCompanyEngineer.Models.AgentEvent>? _eventHandler;
    private HubConnection? _hubConnection;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _agent = await db.Agents.Include(a => a.Group).FirstOrDefaultAsync(a => a.Id == AgentId);

        if (_agent != null)
        {
            // Check if this agent already has a Docker container running
            if (!string.IsNullOrEmpty(_agent.ContainerId))
            {
                // Check if Docker container is actually running via Docker API
                try
                {
                    _dockerAgent = await DockerAgentService.GetAgentByContainerIdAsync(_agent.ContainerId);
                }
                catch
                {
                    _dockerAgent = null;
                }

                if (_dockerAgent != null)
                {
                    // Container is running - update VNC URL from actual container port mappings
                    if (!string.IsNullOrEmpty(_dockerAgent.VncUrl) && _agent.VncUrl != _dockerAgent.VncUrl)
                    {
                        _agent.VncUrl = _dockerAgent.VncUrl;
                        _agent.Status = AgentStatus.Online;
                        db.Agents.Update(_agent);
                        await db.SaveChangesAsync();
                    }
                }
                else
                {
                    // Container is not running - clear stale data
                    _agent.VncUrl = null;
                    _agent.ContainerId = null;
                    _agent.Status = AgentStatus.Offline;
                    db.Agents.Update(_agent);
                    await db.SaveChangesAsync();
                }
            }

            // Connect to SignalR for real-time agent status updates
            await ConnectToSignalR();

            // Connect to Redis (non-blocking)
            try
            {
                _redisConnected = await Redis.ConnectAsync();
            }
            catch
            {
                _redisConnected = false;
            }

            if (_dockerAgent != null && _redisConnected)
            {
                await SubscribeToAgentEvents();
                try
                {
                    await Redis.RequestStatusAsync(_dockerAgent.Id);
                }
                catch { }
            }
        }
    }

    private async Task ConnectToSignalR()
    {
        try
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl(Nav.ToAbsoluteUri("/hubs/agentnetwork"))
                .WithAutomaticReconnect()
                .Build();

            // Handle agent status changes from the network
            _hubConnection.On<dynamic>("AgentStatusChanged", async (status) =>
            {
                await InvokeAsync(() =>
                {
                    try
                    {
                        string agentName = status.agentName?.ToString() ?? "";
                        string newStatus = status.status?.ToString() ?? "offline";

                        // Only update if it's this agent
                        if (_agent != null && _agent.Name == agentName)
                        {
                            _agent.Status = newStatus switch
                            {
                                "online" => AgentStatus.Online,
                                "working" => AgentStatus.Working,
                                "error" => AgentStatus.Error,
                                "starting" => AgentStatus.Starting,
                                _ => AgentStatus.Offline
                            };
                            StateHasChanged();
                        }
                    }
                    catch { }
                });
            });

            _hubConnection.Reconnecting += (ex) =>
            {
                _signalRConnected = false;
                InvokeAsync(StateHasChanged);
                return Task.CompletedTask;
            };

            _hubConnection.Reconnected += async (connectionId) =>
            {
                _signalRConnected = true;
                if (_agent != null)
                {
                    await _hubConnection.InvokeAsync("Connect", _agent.Name);
                }
                await InvokeAsync(StateHasChanged);
            };

            await _hubConnection.StartAsync();
            _signalRConnected = true;

            // Register this agent
            if (_agent != null)
            {
                await _hubConnection.InvokeAsync("Connect", _agent.Name);
            }
        }
        catch
        {
            _signalRConnected = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_dockerAgent != null && _eventHandler != null)
        {
            await Redis.UnsubscribeFromEventsAsync(_dockerAgent.Id, _eventHandler);
        }
        if (_hubConnection != null)
        {
            await _hubConnection.DisposeAsync();
        }
    }

    private async Task SubscribeToAgentEvents()
    {
        if (_dockerAgent == null || !_redisConnected) return;

        _eventHandler = HandleAgentEvent;
        await Redis.SubscribeToEventsAsync(_dockerAgent.Id, _eventHandler);
    }

    private void HandleAgentEvent(AgentCompanyEngineer.Models.AgentEvent agentEvent)
    {
        InvokeAsync(async () =>
        {
            switch (agentEvent.Type)
            {
                case "claude_output":
                    var outputText = ParseClaudeOutput(agentEvent.Data);
                    if (!string.IsNullOrWhiteSpace(outputText))
                    {
                        AddMessage(ChatMessageType.Agent, outputText);
                    }
                    break;

                case "task_started":
                    if (_agent != null)
                    {
                        _agent.Status = AgentStatus.Working;
                        await UpdateAgentStatusInDb(AgentStatus.Working);
                        await BroadcastStatusChange("working");
                    }
                    _isAgentThinking = true;
                    break;

                case "task_completed":
                    if (_agent != null)
                    {
                        _agent.Status = AgentStatus.Online;
                        await UpdateAgentStatusInDb(AgentStatus.Online);
                        await BroadcastStatusChange("online");
                    }
                    _isAgentThinking = false;
                    break;

                case "task_stopped":
                    AddMessage(ChatMessageType.System, "Task stopped");
                    if (_agent != null)
                    {
                        _agent.Status = AgentStatus.Online;
                        await UpdateAgentStatusInDb(AgentStatus.Online);
                        await BroadcastStatusChange("online");
                    }
                    _isAgentThinking = false;
                    break;

                case "status":
                    if (agentEvent.Data.TryGetValue("workspaces", out var wsData) && wsData is System.Text.Json.JsonElement wsArray)
                    {
                        _workspaces = wsArray.EnumerateArray()
                            .Select(ws => new WorkspaceItem
                            {
                                Name = ws.GetProperty("name").GetString() ?? "",
                                RepoUrl = ws.TryGetProperty("repo_url", out var url) ? url.GetString() : null,
                                Branch = ws.TryGetProperty("branch", out var branch) ? branch.GetString() : null,
                                IsActive = ws.TryGetProperty("active", out var active) && active.GetBoolean()
                            })
                            .ToList();
                    }
                    break;

                case "error":
                    AddMessage(ChatMessageType.Error, agentEvent.Data.GetValueOrDefault("message")?.ToString() ?? "Unknown error");
                    if (_agent != null)
                    {
                        _agent.Status = AgentStatus.Error;
                        await UpdateAgentStatusInDb(AgentStatus.Error);
                        await BroadcastStatusChange("error");
                    }
                    break;

                case "daemon_started":
                    if (_agent != null)
                    {
                        _agent.Status = AgentStatus.Online;
                        await UpdateAgentStatusInDb(AgentStatus.Online);
                        await BroadcastStatusChange("online");
                    }
                    AddMessage(ChatMessageType.System, "Agent is ready!");
                    break;

                case "workspace_created":
                case "workspace_switched":
                    if (agentEvent.Type == "workspace_switched" && _dockerAgent != null)
                    {
                        _dockerAgent.CurrentWorkspace = agentEvent.Data.GetValueOrDefault("name")?.ToString();
                    }
                    break;
            }

            StateHasChanged();
        });
    }

    private async Task UpdateAgentStatusInDb(AgentStatus status)
    {
        if (_agent == null) return;

        try
        {
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();
            var agent = await db.Agents.FindAsync(_agent.Id);
            if (agent != null)
            {
                agent.Status = status;
                agent.LastActivityAt = DateTime.UtcNow;
                await db.SaveChangesAsync();
            }
        }
        catch { }
    }

    private async Task BroadcastStatusChange(string status)
    {
        if (_agent == null || _hubConnection == null || !_signalRConnected) return;

        try
        {
            await _hubConnection.InvokeAsync("UpdateStatus", _agent.Name, status, _agent.CurrentTask);
        }
        catch { }
    }

    private void AddMessage(ChatMessageType type, string content)
    {
        _messages.Add(new ChatMessage
        {
            Type = type,
            Content = content,
            Timestamp = DateTime.Now
        });
    }

    private string ParseClaudeOutput(Dictionary<string, object> data)
    {
        try
        {
            if (data.TryGetValue("type", out var typeObj))
            {
                var type = typeObj?.ToString();
                if (type == "system" || type == "result" || type == "user") return "";

                if (type == "assistant" && data.TryGetValue("message", out var msgObj))
                {
                    if (msgObj is System.Text.Json.JsonElement msgElement)
                    {
                        return ExtractAssistantText(msgElement);
                    }
                }
            }
            if (data.TryGetValue("text", out var textObj))
                return textObj?.ToString() ?? "";

            return "";
        }
        catch { return ""; }
    }

    private string ExtractAssistantText(System.Text.Json.JsonElement message)
    {
        try
        {
            if (message.TryGetProperty("content", out var content) && content.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                var texts = new List<string>();
                foreach (var item in content.EnumerateArray())
                {
                    if (item.TryGetProperty("type", out var itemType) && itemType.GetString() == "text")
                    {
                        if (item.TryGetProperty("text", out var textProp))
                            texts.Add(textProp.GetString() ?? "");
                    }
                }
                return string.Join("\n", texts);
            }
            return "";
        }
        catch { return ""; }
    }

    private void GoBack()
    {
        Nav.NavigateTo("/agents");
    }

    private async Task SendTask()
    {
        if (string.IsNullOrWhiteSpace(_taskInput) || _dockerAgent == null) return;

        _messages.Add(new ChatMessage
        {
            Type = ChatMessageType.User,
            Content = _taskInput,
            Timestamp = DateTime.Now
        });

        var task = _taskInput;
        _taskInput = "";
        _isAgentThinking = true;
        if (_agent != null) _agent.Status = AgentStatus.Working;
        StateHasChanged();

        try
        {
            await Redis.SendTaskAsync(_dockerAgent.Id, task);
        }
        catch (Exception ex)
        {
            AddMessage(ChatMessageType.Error, $"Failed to send: {ex.Message}");
            _isAgentThinking = false;
        }

        StateHasChanged();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendTask();
        }
    }

    private async Task StopTask()
    {
        if (_dockerAgent == null) return;

        try
        {
            await Redis.StopTaskAsync(_dockerAgent.Id);
            _isAgentThinking = false;
            if (_agent != null) _agent.Status = AgentStatus.Online;
        }
        catch (Exception ex)
        {
            AddMessage(ChatMessageType.Error, $"Failed to stop: {ex.Message}");
        }
    }

    private async Task StartAgent()
    {
        if (_agent == null || _isStarting) return;

        _isStarting = true;
        StateHasChanged();

        try
        {
            AddMessage(ChatMessageType.System, "Starting agent container...");

            // Get all credentials from the agent's group
            var credentials = new Dictionary<string, string>();
            if (_agent.Group != null)
            {
                credentials = await GroupService.GetAllCredentialsAsync(_agent.Group.Id);
            }

            // Create the Docker container
            _dockerAgent = await DockerAgentService.CreateAgentAsync(_agent.Name, credentials);

            // Update our database agent with the container info
            _agent.ContainerId = _dockerAgent.ContainerId;
            _agent.VncUrl = _dockerAgent.VncUrl;
            _agent.Status = AgentStatus.Starting;
            await using (var db = await DbFactory.CreateDbContextAsync())
            {
                db.Agents.Update(_agent);
                await db.SaveChangesAsync();
            }

            // Connect to Redis and subscribe
            if (!_redisConnected)
            {
                try
                {
                    _redisConnected = await Redis.ConnectAsync();
                }
                catch
                {
                    _redisConnected = false;
                }
            }

            if (_redisConnected)
            {
                await SubscribeToAgentEvents();
            }
            else
            {
                // Redis not available - set status to Online after container starts
                // since we won't receive the daemon_started event
                _agent.Status = AgentStatus.Online;
                await UpdateAgentStatusInDb(AgentStatus.Online);
                await BroadcastStatusChange("online");
                AddMessage(ChatMessageType.System, "Note: Redis not connected - real-time events disabled");
            }

            AddMessage(ChatMessageType.System, $"Container started. VNC: {_dockerAgent.VncUrl}");
        }
        catch (Exception ex)
        {
            AddMessage(ChatMessageType.Error, $"Failed to start: {ex.Message}");
            if (_agent != null) _agent.Status = AgentStatus.Error;
        }
        finally
        {
            _isStarting = false;
            StateHasChanged();
        }
    }

    private async Task SwitchWorkspace(WorkspaceItem ws)
    {
        if (_dockerAgent == null) return;

        foreach (var w in _workspaces) w.IsActive = false;
        ws.IsActive = true;

        try
        {
            await Redis.SwitchWorkspaceAsync(_dockerAgent.Id, ws.Name);
        }
        catch (Exception ex)
        {
            AddMessage(ChatMessageType.Error, $"Failed to switch workspace: {ex.Message}");
        }
    }

    private async Task AddWorkspace()
    {
        if (string.IsNullOrWhiteSpace(_newWorkspaceName) || _dockerAgent == null) return;

        _workspaces.Add(new WorkspaceItem
        {
            Name = _newWorkspaceName,
            RepoUrl = _newWorkspaceUrl,
            Branch = _newWorkspaceBranch
        });

        try
        {
            // Get GitHub token for private repos
            string? githubToken = null;
            if (_agent?.Group != null)
            {
                githubToken = await GroupService.GetGitHubTokenAsync(_agent.Group.Id);
            }

            await Redis.CreateWorkspaceAsync(
                _dockerAgent.Id,
                _newWorkspaceName,
                _newWorkspaceUrl,
                string.IsNullOrWhiteSpace(_newWorkspaceBranch) ? "main" : _newWorkspaceBranch,
                githubToken);

            AddMessage(ChatMessageType.System, $"Cloning {_newWorkspaceUrl} to {_newWorkspaceName}...");
        }
        catch (Exception ex)
        {
            AddMessage(ChatMessageType.Error, $"Failed to create workspace: {ex.Message}");
        }

        _showAddWorkspace = false;
        _newWorkspaceName = "";
        _newWorkspaceUrl = "";
        _newWorkspaceBranch = "main";
    }

    private string GetStatusClass(AgentStatus status) => status switch
    {
        AgentStatus.Online => "status-online",
        AgentStatus.Working => "status-working",
        AgentStatus.Error => "status-error",
        AgentStatus.Starting => "status-starting",
        _ => "status-offline"
    };

    private class WorkspaceItem
    {
        public string Name { get; set; } = "";
        public string? RepoUrl { get; set; }
        public string? Branch { get; set; }
        public bool IsActive { get; set; }
    }

    private class ChatMessage
    {
        public ChatMessageType Type { get; set; }
        public string Content { get; set; } = "";
        public DateTime Timestamp { get; set; }
    }

    private enum ChatMessageType
    {
        User,
        Agent,
        System,
        Error
    }
}
