@page "/agent/{AgentId:int}"
@using AgentCompanyWeb.Data
@using AgentCompanyWeb.Data.Models
@using AgentCompanyWeb.Services
@using AgentCompanyEngineer.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.SignalR.Client
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject AgentService DockerAgentService
@inject RedisService Redis
@inject GroupService GroupService
@inject IServiceScopeFactory ScopeFactory
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>@(_agent?.Name ?? "Agent") - Agent Company</PageTitle>

<div class="agent-detail-layout @(_viewMode)">
    <!-- Status Bar (visible in split/fullscreen modes) -->
    @if (_viewMode != "chat")
    {
        <div class="status-bar">
            <button class="btn btn-ghost btn-icon" @onclick="GoBack" title="Back to Agents">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 12H5M12 19l-7-7 7-7"/>
                </svg>
            </button>
            <div class="status-bar-info">
                <span class="status-dot @GetStatusClass(_agent?.Status ?? AgentStatus.Offline)"></span>
                <span class="status-bar-name">@(_agent?.Name ?? "Agent")</span>
                @if (_agent?.Status == AgentStatus.Working)
                {
                    <span class="status-bar-status working">Working</span>
                }
                else if (_agent?.Status == AgentStatus.Starting)
                {
                    <span class="status-bar-status starting">Starting...</span>
                }
                else if (_agent?.Status == AgentStatus.Online)
                {
                    <span class="status-bar-status online">Online</span>
                }
                else if (_agent?.Status == AgentStatus.Error)
                {
                    <span class="status-bar-status error">Error</span>
                }
                else
                {
                    <span class="status-bar-status offline">Offline</span>
                }
            </div>
            @if (_redisConnected || _signalRConnected)
            {
                <span class="connection-badge connected" title="@(_redisConnected ? "Redis" : "") @(_signalRConnected ? "SignalR" : "") connected">
                    @if (_redisConnected && _signalRConnected)
                    {
                        <text>Live</text>
                    }
                    else if (_signalRConnected)
                    {
                        <text>Network</text>
                    }
                    else
                    {
                        <text>Redis</text>
                    }
                </span>
            }
            else
            {
                <span class="connection-badge disconnected" title="Reconnecting...">Offline</span>
            }
            @if (_agent?.Status == AgentStatus.Working)
            {
                <button class="btn btn-ghost btn-sm danger" @onclick="StopTask" title="Stop Task">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="6" y="6" width="12" height="12" rx="2"/>
                    </svg>
                    Stop
                </button>
            }
        </div>
    }

    <!-- Sidebar (hidden in split and fullscreen modes) -->
    <div class="agent-sidebar @(_viewMode != "chat" ? "hidden" : "")">
        <div class="sidebar-header">
            <button class="btn btn-ghost btn-icon" @onclick="GoBack" title="Back to Agents">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 12H5M12 19l-7-7 7-7"/>
                </svg>
            </button>
            <div class="agent-info">
                <span class="status-dot @GetStatusClass(_agent?.Status ?? AgentStatus.Offline)"></span>
                <span class="agent-name">@(_agent?.Name ?? "Loading...")</span>
            </div>
            <div class="header-actions">
                @if (_redisConnected)
                {
                    <span class="connection-indicator connected" title="Connected to Redis"></span>
                }
                @if (_agent?.Status == AgentStatus.Working)
                {
                    <button class="btn btn-ghost btn-icon danger" @onclick="StopTask" title="Stop Task">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="6" y="6" width="12" height="12" rx="2"/>
                        </svg>
                    </button>
                }
            </div>
        </div>

        <div class="agent-meta">
            @if (!string.IsNullOrEmpty(_agent?.Role))
            {
                <span class="role-tag">@_agent.Role</span>
            }
            <span class="model-tag">@(_agent?.Model?.ToUpper() ?? "SONNET")</span>
            <span class="group-tag">@(_agent?.Group?.Name ?? "Default")</span>
        </div>

        <!-- Workspaces Section -->
        <div class="sidebar-section">
            <div class="section-header">
                <span class="section-title">Workspaces</span>
                <button class="btn btn-ghost btn-icon small" @onclick="() => _showAddWorkspace = true" title="Add Workspace">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                </button>
            </div>
            <div class="workspace-list">
                @foreach (var ws in _workspaces)
                {
                    <button class="workspace-item @(ws.IsActive ? "active" : "")" @onclick="async () => await SwitchWorkspace(ws)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                        </svg>
                        <span>@ws.Name</span>
                    </button>
                }
                @if (_workspaces.Count == 0)
                {
                    <p class="empty-hint">No workspaces yet</p>
                }
            </div>
        </div>

        <!-- Current Task Section -->
        @if (!string.IsNullOrEmpty(_agent?.CurrentTask))
        {
            <div class="sidebar-section">
                <div class="section-header">
                    <span class="section-title">Current Task</span>
                </div>
                <div class="current-task-display">
                    @_agent.CurrentTask
                </div>
            </div>
        }
    </div>

    <!-- Main Content Area -->
    <div class="agent-main">
        <!-- View Mode Toggle -->
        <div class="view-toggle">
            <button class="toggle-btn @(_viewMode == "chat" ? "active" : "")" @onclick='() => _viewMode = "chat"' title="Chat Only">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                </svg>
            </button>
            <button class="toggle-btn @(_viewMode == "split" ? "active" : "")" @onclick='() => _viewMode = "split"' title="Split View">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <line x1="12" y1="3" x2="12" y2="21"/>
                </svg>
            </button>
            <button class="toggle-btn @(_viewMode == "fullscreen" ? "active" : "")" @onclick='() => _viewMode = "fullscreen"' title="Fullscreen Desktop">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="3" width="20" height="14" rx="2"/>
                    <line x1="8" y1="21" x2="16" y2="21"/>
                    <line x1="12" y1="17" x2="12" y2="21"/>
                </svg>
            </button>
        </div>

        <!-- Chat Panel -->
        @if (_viewMode != "fullscreen")
        {
            <div class="chat-panel @(_viewMode == "split" ? "split" : "")">
                <div class="messages-container" @ref="_messagesRef">
                    @foreach (var msg in _messages)
                    {
                        <div class="chat-message @msg.Type.ToString().ToLower()">
                            @if (msg.Type == ChatMessageType.User)
                            {
                                <div class="message-header">
                                    <span class="sender">You</span>
                                    <span class="time">@msg.Timestamp.ToString("HH:mm")</span>
                                </div>
                            }
                            else if (msg.Type == ChatMessageType.Agent)
                            {
                                <div class="message-header">
                                    <span class="sender">@_agent?.Name</span>
                                    <span class="time">@msg.Timestamp.ToString("HH:mm")</span>
                                </div>
                            }
                            <div class="message-body">@msg.Content</div>
                        </div>
                    }
                    @if (_messages.Count == 0)
                    {
                        <div class="empty-chat">
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                            </svg>
                            <p>Send a task to start working with the agent</p>
                        </div>
                    }
                    @if (_isAgentThinking)
                    {
                        <div class="thinking-indicator">
                            <div class="typing-dots">
                                <span></span><span></span><span></span>
                            </div>
                            <span>Agent is thinking...</span>
                        </div>
                    }
                </div>

                <div class="input-area">
                    <textarea class="task-input" placeholder="Describe a task for the agent..."
                              @bind="_taskInput" @bind:event="oninput"
                              @onkeydown="HandleKeyDown" rows="3"></textarea>
                    <button class="btn btn-primary send-btn" @onclick="SendTask"
                            disabled="@(string.IsNullOrWhiteSpace(_taskInput) || _isAgentThinking)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="22" y1="2" x2="11" y2="13"></line>
                            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                        </svg>
                    </button>
                </div>
            </div>
        }

        <!-- VNC Desktop Panel -->
        @if (_viewMode == "split" || _viewMode == "fullscreen")
        {
            <div class="vnc-panel @(_viewMode == "fullscreen" ? "fullscreen" : "")">
                @if (!string.IsNullOrEmpty(_agent?.VncUrl))
                {
                    <iframe src="@_agent.VncUrl" class="vnc-frame" title="Agent Desktop"></iframe>
                }
                else
                {
                    <div class="vnc-placeholder">
                        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <rect x="2" y="3" width="20" height="14" rx="2"/>
                            <line x1="8" y1="21" x2="16" y2="21"/>
                            <line x1="12" y1="17" x2="12" y2="21"/>
                        </svg>
                        <h3>Desktop Not Available</h3>
                        <p>Start the agent to access its desktop</p>
                        <button class="btn btn-primary" @onclick="StartAgent">Start Agent</button>
                    </div>
                }
                @if (_viewMode == "fullscreen")
                {
                    <button class="exit-fullscreen-btn" @onclick='() => _viewMode = "split"'>
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="18" y1="6" x2="6" y2="18"></line>
                            <line x1="6" y1="6" x2="18" y2="18"></line>
                        </svg>
                        Exit Fullscreen
                    </button>
                }
            </div>
        }
    </div>
</div>

<!-- Add Workspace Modal -->
@if (_showAddWorkspace)
{
    <div class="modal-overlay active" @onclick="() => _showAddWorkspace = false"></div>
    <div class="modal active">
        <div class="modal-header">
            <h3>Add Workspace</h3>
            <button class="btn btn-ghost btn-icon" @onclick="() => _showAddWorkspace = false">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label class="form-label">Folder Name</label>
                <input type="text" class="form-input" placeholder="my-project" @bind="_newWorkspaceName" />
            </div>
            <div class="form-group">
                <label class="form-label">Git Repository URL</label>
                <input type="text" class="form-input" placeholder="https://github.com/user/repo.git" @bind="_newWorkspaceUrl" />
            </div>
            <div class="form-group">
                <label class="form-label">Branch</label>
                <input type="text" class="form-input" placeholder="main" @bind="_newWorkspaceBranch" />
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" @onclick="() => _showAddWorkspace = false">Cancel</button>
            <button class="btn btn-primary" @onclick="async () => await AddWorkspace()">Add Workspace</button>
        </div>
    </div>
}

<style>
    .agent-detail-layout {
        display: flex;
        flex-direction: row;
        height: 100%;
        min-height: 100%;
        background: var(--bg-app, #F5F5F7);
    }

    /* Chat mode: sidebar visible, full chat */
    .agent-detail-layout.chat {
        flex-direction: row;
    }

    .agent-detail-layout.chat .agent-main {
        flex-direction: column;
    }

    /* Split mode: cover ENTIRE screen including main sidebar */
    .agent-detail-layout.split {
        position: fixed !important;
        inset: 0 !important;
        z-index: 9999 !important;
        margin: 0 !important;
        padding: 0 !important;
        width: 100vw !important;
        height: 100vh !important;
        max-width: 100vw !important;
        max-height: 100vh !important;
        flex-direction: column;
        background: var(--bg-app, #F5F5F7);
        overflow: hidden;
    }

    .agent-detail-layout.split .agent-main {
        flex-direction: row;
        flex: 1;
        min-height: 0;
    }

    /* Fullscreen mode: only VNC, cover ENTIRE screen */
    .agent-detail-layout.fullscreen {
        position: fixed !important;
        inset: 0 !important;
        z-index: 9999 !important;
        margin: 0 !important;
        padding: 0 !important;
        width: 100vw !important;
        height: 100vh !important;
        max-width: 100vw !important;
        max-height: 100vh !important;
        flex-direction: column;
        background: #1a1a1a;
        overflow: hidden;
    }

    /* Status bar for split/fullscreen modes */
    .status-bar {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 8px 16px;
        background: var(--bg-card);
        border-bottom: 1px solid var(--border);
        height: 48px;
        flex-shrink: 0;
    }

    .status-bar-info {
        display: flex;
        align-items: center;
        gap: 8px;
        flex: 1;
    }

    .status-bar-name {
        font-weight: 600;
        font-size: 14px;
    }

    .status-bar-status {
        font-size: 12px;
        padding: 2px 8px;
        border-radius: var(--radius-full);
    }

    .status-bar-status.online {
        background: rgba(52, 199, 89, 0.15);
        color: var(--success);
    }

    .status-bar-status.working {
        background: rgba(255, 159, 10, 0.15);
        color: var(--warning);
    }

    .status-bar-status.starting {
        background: rgba(90, 200, 250, 0.15);
        color: #5AC8FA;
        animation: pulse 1s infinite;
    }

    .status-bar-status.error {
        background: rgba(255, 59, 48, 0.15);
        color: var(--danger);
    }

    .status-bar-status.offline {
        background: var(--bg-secondary);
        color: var(--text-tertiary);
    }

    .connection-badge {
        font-size: 11px;
        padding: 2px 8px;
        border-radius: var(--radius-full);
        background: rgba(52, 199, 89, 0.15);
        color: var(--success);
    }

    .connection-badge.connected::before {
        content: "";
        display: inline-block;
        width: 6px;
        height: 6px;
        background: var(--success);
        border-radius: 50%;
        margin-right: 6px;
    }

    .connection-badge.disconnected {
        background: rgba(255, 159, 10, 0.15);
        color: var(--warning);
    }

    .connection-badge.disconnected::before {
        content: "";
        display: inline-block;
        width: 6px;
        height: 6px;
        background: var(--warning);
        border-radius: 50%;
        margin-right: 6px;
        animation: pulse 1s infinite;
    }

    .btn-sm {
        padding: 4px 10px;
        font-size: 12px;
    }

    .btn-sm svg {
        margin-right: 4px;
    }

    .agent-sidebar {
        width: 280px;
        background: var(--bg-card);
        border-right: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        overflow-y: auto;
        transition: width 0.2s ease, opacity 0.2s ease;
    }

    .agent-sidebar.hidden {
        display: none !important;
    }

    .sidebar-header {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 16px;
        border-bottom: 1px solid var(--border);
    }

    .agent-info {
        display: flex;
        align-items: center;
        gap: 8px;
        flex: 1;
    }

    .agent-name {
        font-weight: 600;
        font-size: 15px;
    }

    .agent-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        padding: 12px 16px;
        border-bottom: 1px solid var(--border);
    }

    .role-tag, .model-tag, .group-tag {
        padding: 2px 8px;
        border-radius: var(--radius-full);
        font-size: 11px;
        font-weight: 500;
    }

    .role-tag {
        background: var(--bg-active);
        color: var(--accent);
    }

    .model-tag {
        background: var(--bg-secondary);
        color: var(--text-secondary);
    }

    .group-tag {
        background: rgba(52, 199, 89, 0.1);
        color: var(--success);
    }

    .sidebar-section {
        padding: 16px;
        border-bottom: 1px solid var(--border);
    }

    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 12px;
    }

    .section-title {
        font-size: 12px;
        font-weight: 600;
        color: var(--text-tertiary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .workspace-list {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .workspace-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        background: none;
        border: none;
        border-radius: var(--radius-md);
        cursor: pointer;
        font-size: 13px;
        color: var(--text-secondary);
        transition: all 0.15s ease;
        text-align: left;
        width: 100%;
    }

    .workspace-item:hover {
        background: var(--bg-hover);
    }

    .workspace-item.active {
        background: var(--bg-active);
        color: var(--accent);
    }

    .empty-hint {
        font-size: 12px;
        color: var(--text-tertiary);
        text-align: center;
        padding: 12px;
    }

    .current-task-display {
        font-size: 13px;
        color: var(--text-secondary);
        background: var(--bg-secondary);
        padding: 12px;
        border-radius: var(--radius-md);
        line-height: 1.5;
    }

    .agent-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        position: relative;
        overflow: hidden;
        min-height: 0; /* Important for flex children to shrink */
    }

    .agent-detail-layout.split .agent-main {
        flex-direction: row;
        flex: 1;
        min-height: 0;
    }

    .agent-detail-layout.fullscreen .agent-main {
        flex: 1;
        min-height: 0;
    }

    .view-toggle {
        position: absolute;
        top: 16px;
        right: 16px;
        display: flex;
        background: var(--bg-card);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-sm);
        z-index: 10;
    }

    .toggle-btn {
        padding: 8px 12px;
        background: none;
        border: none;
        cursor: pointer;
        color: var(--text-tertiary);
        transition: all 0.15s ease;
    }

    .toggle-btn:hover {
        color: var(--text-primary);
    }

    .toggle-btn.active {
        color: var(--accent);
        background: var(--bg-active);
    }

    .toggle-btn:first-child {
        border-radius: var(--radius-md) 0 0 var(--radius-md);
    }

    .toggle-btn:last-child {
        border-radius: 0 var(--radius-md) var(--radius-md) 0;
    }

    .chat-panel {
        flex: 1;
        display: flex;
        flex-direction: column;
        padding: 16px;
        min-height: 0;
        background: var(--bg-secondary, #F5F5F7);
    }

    .agent-detail-layout.split .chat-panel {
        width: 380px;
        min-width: 320px;
        max-width: 450px;
        flex: none;
        border-right: 1px solid var(--border);
        background: var(--bg-card, white);
        border-radius: 0;
    }

    .messages-container {
        flex: 1;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 16px;
        margin-bottom: 16px;
    }

    .chat-message {
        max-width: 80%;
        padding: 12px 16px;
        border-radius: var(--radius-lg);
        background: var(--bg-card);
        box-shadow: var(--shadow-xs);
    }

    .chat-message.user {
        margin-left: auto;
        background: var(--accent);
        color: white;
    }

    .chat-message.agent {
        margin-right: auto;
    }

    .chat-message.system {
        margin: 0 auto;
        background: var(--bg-secondary);
        font-size: 12px;
        color: var(--text-tertiary);
    }

    .message-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 4px;
        font-size: 12px;
    }

    .sender {
        font-weight: 600;
    }

    .time {
        color: var(--text-tertiary);
    }

    .chat-message.user .time {
        color: rgba(255, 255, 255, 0.7);
    }

    .message-body {
        font-size: 14px;
        line-height: 1.5;
        white-space: pre-wrap;
    }

    .empty-chat {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        color: var(--text-tertiary);
        text-align: center;
        gap: 12px;
    }

    .empty-chat svg {
        opacity: 0.4;
    }

    .thinking-indicator {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        background: var(--bg-card);
        border-radius: var(--radius-lg);
        font-size: 13px;
        color: var(--text-secondary);
    }

    .typing-dots {
        display: flex;
        gap: 4px;
    }

    .typing-dots span {
        width: 8px;
        height: 8px;
        background: var(--accent);
        border-radius: 50%;
        animation: bounce 1.4s infinite ease-in-out both;
    }

