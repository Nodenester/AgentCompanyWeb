@page "/monitor"
@using AgentCompanyWeb.Data
@using AgentCompanyWeb.Data.Models
@using AgentCompanyWeb.Components.Shared
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.SignalR.Client
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Nav
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>Monitoring - Agent Company</PageTitle>

<div class="page-header">
    <h1 class="page-title">Monitoring</h1>
    <div class="page-actions">
        <span class="last-refresh">Last refresh: @_lastRefresh.ToString("HH:mm:ss")</span>
        <button class="btn btn-secondary" @onclick="RefreshData">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="23 4 23 10 17 10"></polyline>
                <polyline points="1 20 1 14 7 14"></polyline>
                <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
            </svg>
            Refresh
        </button>
    </div>
</div>

<div class="monitor-page">
    <!-- System Health Bar -->
    <div class="health-bar-section">
        <div class="health-bar-header">
            <span class="health-label">System Health</span>
            <span class="health-value @GetHealthClass(_healthPercent)">@_healthPercent%</span>
        </div>
        <div class="health-bar">
            <div class="health-bar-fill @GetHealthClass(_healthPercent)" style="width: @_healthPercent%"></div>
        </div>
        <div class="health-breakdown">
            <span class="health-stat"><span class="dot online"></span> @_onlineCount Online</span>
            <span class="health-stat"><span class="dot working"></span> @_workingCount Working</span>
            <span class="health-stat"><span class="dot error"></span> @_errorCount Errors</span>
            <span class="health-stat"><span class="dot offline"></span> @_offlineCount Offline</span>
        </div>
    </div>

    <div class="monitor-grid">
        <!-- Agent Status Grid -->
        <div class="monitor-panel agent-grid-panel">
            <div class="panel-header">
                <h3>Agent Status Grid</h3>
                <span class="panel-subtitle">@_agents.Count total agents</span>
            </div>
            <div class="agent-status-grid">
                @if (_agents.Count == 0)
                {
                    <div class="empty-grid">No agents configured</div>
                }
                else
                {
                    @foreach (var agent in _agents)
                    {
                        <div class="agent-status-cell @GetStatusClass(agent.Status)"
                             title="@agent.Name - @agent.Status"
                             @onclick="() => NavigateToAgent(agent.Id)">
                            @if (agent.Status == AgentStatus.Error)
                            {
                                <span class="cell-icon">!</span>
                            }
                            else if (agent.Status == AgentStatus.Working)
                            {
                                <span class="cell-icon working-icon"></span>
                            }
                        </div>
                    }
                }
            </div>
            <div class="grid-legend">
                <span><span class="legend-dot online"></span> Online</span>
                <span><span class="legend-dot working"></span> Working</span>
                <span><span class="legend-dot offline"></span> Offline</span>
                <span><span class="legend-dot error"></span> Error</span>
            </div>
        </div>

        <!-- Quick Metrics -->
        <div class="monitor-panel metrics-panel">
            <div class="panel-header">
                <h3>Quick Metrics</h3>
                <span class="panel-subtitle">Last 24 hours</span>
            </div>
            <div class="metrics-grid">
                <div class="metric-item">
                    <div class="metric-value">@_tasksCompleted</div>
                    <div class="metric-label">Tasks Completed</div>
                </div>
                <div class="metric-item">
                    <div class="metric-value">@_messagesSent</div>
                    <div class="metric-label">Messages Sent</div>
                </div>
                <div class="metric-item">
                    <div class="metric-value">@_triggersExecuted</div>
                    <div class="metric-label">Triggers Executed</div>
                </div>
                <div class="metric-item">
                    <div class="metric-value">@_uptime</div>
                    <div class="metric-label">Avg Uptime</div>
                </div>
            </div>
        </div>

        <!-- Active Alerts -->
        <div class="monitor-panel alerts-panel">
            <div class="panel-header">
                <h3>Active Alerts</h3>
                @if (_alerts.Count > 0)
                {
                    <span class="alert-badge">@_alerts.Count</span>
                }
            </div>
            <div class="alerts-list">
                @if (_alerts.Count == 0)
                {
                    <div class="no-alerts">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                            <polyline points="22 4 12 14.01 9 11.01"></polyline>
                        </svg>
                        <span>All systems operational</span>
                    </div>
                }
                else
                {
                    @foreach (var alert in _alerts)
                    {
                        <div class="alert-item @(alert.IsError ? "error" : "warning")" @onclick="() => NavigateToAgent(alert.AgentId)">
                            <div class="alert-icon">
                                @if (alert.IsError)
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10"></circle>
                                        <line x1="15" y1="9" x2="9" y2="15"></line>
                                        <line x1="9" y1="9" x2="15" y2="15"></line>
                                    </svg>
                                }
                                else
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                                        <line x1="12" y1="9" x2="12" y2="13"></line>
                                        <line x1="12" y1="17" x2="12.01" y2="17"></line>
                                    </svg>
                                }
                            </div>
                            <div class="alert-content">
                                <span class="alert-title">@alert.Title</span>
                                <span class="alert-agent">@alert.AgentName</span>
                            </div>
                            <span class="alert-time">@GetRelativeTime(alert.Time)</span>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Recent Logs -->
    <div class="monitor-panel logs-panel">
        <div class="panel-header">
            <h3>Recent System Logs</h3>
            <div class="log-filters">
                <button class="log-filter @(_logFilter == "all" ? "active" : "")" @onclick='() => _logFilter = "all"'>All</button>
                <button class="log-filter @(_logFilter == "info" ? "active" : "")" @onclick='() => _logFilter = "info"'>Info</button>
                <button class="log-filter @(_logFilter == "warn" ? "active" : "")" @onclick='() => _logFilter = "warn"'>Warn</button>
                <button class="log-filter @(_logFilter == "error" ? "active" : "")" @onclick='() => _logFilter = "error"'>Error</button>
            </div>
        </div>
        <div class="logs-content">
            @foreach (var log in FilteredLogs)
            {
                <div class="log-entry @log.Level.ToLower()">
                    <span class="log-time">@log.Time.ToString("HH:mm:ss")</span>
                    <span class="log-level">[@log.Level.ToUpper()]</span>
                    <span class="log-message">@log.Message</span>
                    @if (!string.IsNullOrEmpty(log.Source))
                    {
                        <span class="log-source">@log.Source</span>
                    }
                </div>
            }
            @if (!FilteredLogs.Any())
            {
                <div class="no-logs">No logs matching filter</div>
            }
        </div>
    </div>
</div>

<style>
    .monitor-page {
        padding: 0 32px 32px;
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .last-refresh {
        font-size: 12px;
        color: var(--text-tertiary);
    }

    /* Health Bar */
    .health-bar-section {
        background: var(--bg-card);
        border-radius: var(--radius-lg);
        padding: 20px 24px;
        border: 1px solid var(--border-light);
    }

    .health-bar-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 12px;
    }

    .health-label {
        font-size: 14px;
        font-weight: 600;
        color: var(--text-primary);
    }

    .health-value {
        font-size: 24px;
        font-weight: 700;
    }

    .health-value.good { color: var(--success); }
    .health-value.warning { color: var(--warning); }
    .health-value.critical { color: var(--danger); }

    .health-bar {
        height: 12px;
        background: var(--bg-hover);
        border-radius: var(--radius-full);
        overflow: hidden;
        margin-bottom: 12px;
    }

    .health-bar-fill {
        height: 100%;
        border-radius: var(--radius-full);
        transition: width 0.5s ease;
    }

    .health-bar-fill.good { background: var(--success); }
    .health-bar-fill.warning { background: var(--warning); }
    .health-bar-fill.critical { background: var(--danger); }

    .health-breakdown {
        display: flex;
        gap: 24px;
    }

    .health-stat {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: var(--text-secondary);
    }

    .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    .dot.online { background: var(--success); }
    .dot.working { background: var(--warning); }
    .dot.error { background: var(--danger); }
    .dot.offline { background: var(--text-tertiary); }

    /* Monitor Grid */
    .monitor-grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: 20px;
    }

    .monitor-panel {
        background: var(--bg-card);
        border-radius: var(--radius-lg);
        border: 1px solid var(--border-light);
        overflow: hidden;
    }

    .panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 20px;
        border-bottom: 1px solid var(--border-light);
    }

    .panel-header h3 {
        font-size: 14px;
        font-weight: 600;
        color: var(--text-primary);
        margin: 0;
    }

    .panel-subtitle {
        font-size: 12px;
        color: var(--text-tertiary);
    }

    /* Agent Status Grid */
    .agent-status-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(24px, 1fr));
        gap: 4px;
        padding: 16px 20px;
    }

    .agent-status-cell {
        aspect-ratio: 1;
        border-radius: 4px;
        cursor: pointer;
        transition: transform 0.15s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: bold;
    }

    .agent-status-cell:hover {
        transform: scale(1.2);
        z-index: 1;
    }

    .agent-status-cell.status-online { background: var(--success); }
    .agent-status-cell.status-working { background: var(--warning); }
    .agent-status-cell.status-offline { background: var(--text-tertiary); opacity: 0.5; }
    .agent-status-cell.status-error { background: var(--danger); }
    .agent-status-cell.status-starting { background: #5AC8FA; }

    .cell-icon { color: white; }
    .working-icon {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: white;
        animation: pulse 1s ease-in-out infinite;
    }

    .empty-grid {
        padding: 32px;
        text-align: center;
        color: var(--text-tertiary);
        font-size: 13px;
    }

    .grid-legend {
        display: flex;
        gap: 16px;
        padding: 12px 20px;
        background: var(--bg-hover);
        font-size: 11px;
        color: var(--text-secondary);
    }

    .legend-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 2px;
        margin-right: 4px;
    }

    .legend-dot.online { background: var(--success); }
    .legend-dot.working { background: var(--warning); }
    .legend-dot.offline { background: var(--text-tertiary); }
    .legend-dot.error { background: var(--danger); }

    /* Metrics */
    .metrics-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1px;
        background: var(--border-light);
    }

    .metric-item {
        padding: 16px;
        background: var(--bg-card);
        text-align: center;
    }

    .metric-value {
        font-size: 24px;
        font-weight: 600;
        color: var(--text-primary);
    }

    .metric-label {
        font-size: 11px;
        color: var(--text-tertiary);
        margin-top: 4px;
    }

    /* Alerts */
    .alert-badge {
        background: var(--danger);
        color: white;
        font-size: 11px;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: var(--radius-full);
    }

    .alerts-list {
        padding: 12px;
    }

    .no-alerts {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        padding: 24px;
        color: var(--success);
    }

    .alert-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        border-radius: var(--radius-md);
        cursor: pointer;
        transition: background 0.15s ease;
        margin-bottom: 4px;
    }

    .alert-item:hover {
        background: var(--bg-hover);
    }

    .alert-item.error .alert-icon { color: var(--danger); }
    .alert-item.warning .alert-icon { color: var(--warning); }

    .alert-content {
        flex: 1;
        min-width: 0;
    }

    .alert-title {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: var(--text-primary);
    }

    .alert-agent {
        font-size: 11px;
        color: var(--text-tertiary);
    }

    .alert-time {
        font-size: 10px;
        color: var(--text-tertiary);
    }

    /* Logs Panel */
    .logs-panel {
        max-height: 300px;
        display: flex;
        flex-direction: column;
    }

    .log-filters {
        display: flex;
        gap: 4px;
    }

    .log-filter {
        padding: 4px 10px;
        background: var(--bg-hover);
        border: none;
        border-radius: var(--radius-sm);
        font-size: 11px;
        color: var(--text-secondary);
        cursor: pointer;
    }

    .log-filter.active {
        background: var(--accent);
        color: white;
    }

    .logs-content {
        flex: 1;
        overflow-y: auto;
        padding: 12px 16px;
        font-family: 'SF Mono', 'Consolas', monospace;
        font-size: 12px;
    }

    .log-entry {
        display: flex;
        gap: 12px;
        padding: 4px 0;
        border-bottom: 1px solid var(--border-light);
    }

    .log-time {
        color: var(--text-tertiary);
        flex-shrink: 0;
    }

    .log-level {
        flex-shrink: 0;
        width: 50px;
    }

    .log-entry.info .log-level { color: var(--accent); }
    .log-entry.warn .log-level { color: var(--warning); }
    .log-entry.error .log-level { color: var(--danger); }

    .log-message {
        flex: 1;
        color: var(--text-primary);
    }

    .log-source {
        color: var(--text-tertiary);
        flex-shrink: 0;
    }

    .no-logs {
        padding: 24px;
        text-align: center;
        color: var(--text-tertiary);
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }
</style>

@code {
    private List<Agent> _agents = new();
    private List<AlertInfo> _alerts = new();
    private List<LogEntry> _logs = new();
    private string _logFilter = "all";
    private DateTime _lastRefresh = DateTime.Now;

    private int _onlineCount = 0;
    private int _workingCount = 0;
    private int _errorCount = 0;
    private int _offlineCount = 0;
    private int _healthPercent = 100;

    private int _tasksCompleted = 0;
    private int _messagesSent = 0;
    private int _triggersExecuted = 0;
    private string _uptime = "99.9%";

    private HubConnection? _hubConnection;

    private IEnumerable<LogEntry> FilteredLogs => _logFilter == "all"
        ? _logs
        : _logs.Where(l => l.Level.ToLower() == _logFilter);

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        await ConnectToSignalR();
    }

    private async Task LoadData()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        _agents = await db.Agents.OrderBy(a => a.Name).ToListAsync();

        // Calculate health metrics
        _onlineCount = _agents.Count(a => a.Status == AgentStatus.Online);
        _workingCount = _agents.Count(a => a.Status == AgentStatus.Working);
        _errorCount = _agents.Count(a => a.Status == AgentStatus.Error);
        _offlineCount = _agents.Count(a => a.Status == AgentStatus.Offline);

        var totalAgents = _agents.Count;
        if (totalAgents > 0)
        {
            var healthyCount = _onlineCount + _workingCount;
            _healthPercent = (int)((healthyCount * 100.0) / totalAgents);
        }

        // Load alerts
        _alerts.Clear();
        foreach (var agent in _agents.Where(a => a.Status == AgentStatus.Error))
        {
            _alerts.Add(new AlertInfo
            {
                IsError = true,
                Title = "Agent Error",
                AgentName = agent.Name,
                AgentId = agent.Id,
                Time = agent.LastActivityAt
            });
        }

        // Load metrics
        var yesterday = DateTime.UtcNow.AddDays(-1);
        _messagesSent = await db.NetworkMessages.CountAsync(m => m.Timestamp >= yesterday);
        _triggersExecuted = await db.TriggerLogs.CountAsync(t => t.ExecutedAt >= yesterday);
        _tasksCompleted = await db.CronJobLogs.CountAsync(c => c.StartedAt >= yesterday && c.Status == JobExecutionStatus.Success);

        // Generate sample logs (in a real system, these would come from a logging service)
        GenerateSampleLogs();

        _lastRefresh = DateTime.Now;
    }

    private void GenerateSampleLogs()
    {
        _logs.Clear();

        // Add some sample log entries
        var now = DateTime.Now;
        _logs.Add(new LogEntry { Time = now.AddMinutes(-1), Level = "INFO", Message = "System health check completed", Source = "Monitor" });
        _logs.Add(new LogEntry { Time = now.AddMinutes(-2), Level = "INFO", Message = "Agent connected to network", Source = "Network" });

        if (_errorCount > 0)
        {
            _logs.Add(new LogEntry { Time = now.AddMinutes(-3), Level = "ERROR", Message = $"{_errorCount} agent(s) in error state", Source = "Health" });
        }

        if (_workingCount > 0)
        {
            _logs.Add(new LogEntry { Time = now.AddMinutes(-4), Level = "INFO", Message = $"{_workingCount} agent(s) currently working", Source = "Status" });
        }

        _logs.Add(new LogEntry { Time = now.AddMinutes(-5), Level = "INFO", Message = "SignalR hub connection established", Source = "Hub" });

        _logs = _logs.OrderByDescending(l => l.Time).ToList();
    }

    private async Task RefreshData()
    {
        await LoadData();
        StateHasChanged();
    }

    private async Task ConnectToSignalR()
    {
        try
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl(Nav.ToAbsoluteUri("/hubs/agentnetwork"))
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<dynamic>("AgentStatusChanged", async (status) =>
            {
                await InvokeAsync(async () =>
                {
                    await LoadData();
                    StateHasChanged();
                });
            });

            await _hubConnection.StartAsync();
        }
        catch { }
    }

    private void NavigateToAgent(int id) => Nav.NavigateTo($"/agent/{id}");

    private string GetStatusClass(AgentStatus status) => status switch
    {
        AgentStatus.Online => "status-online",
        AgentStatus.Working => "status-working",
        AgentStatus.Error => "status-error",
        AgentStatus.Starting => "status-starting",
        _ => "status-offline"
    };

    private string GetHealthClass(int percent) => percent switch
    {
        >= 80 => "good",
        >= 50 => "warning",
        _ => "critical"
    };

    private string GetRelativeTime(DateTime time)
    {
        var diff = DateTime.Now - time;
        if (diff.TotalMinutes < 1) return "Just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        return time.ToString("MMM d");
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection != null)
        {
            await _hubConnection.DisposeAsync();
        }
    }

    private class AlertInfo
    {
        public bool IsError { get; set; }
        public string Title { get; set; } = "";
        public string AgentName { get; set; } = "";
        public int AgentId { get; set; }
        public DateTime Time { get; set; }
    }

    private class LogEntry
    {
        public DateTime Time { get; set; }
        public string Level { get; set; } = "INFO";
        public string Message { get; set; } = "";
        public string? Source { get; set; }
    }
}
