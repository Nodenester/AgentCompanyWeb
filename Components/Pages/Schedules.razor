@code {
    [Parameter]
    public int? GroupId { get; set; }

    private List<Group> _groups = new();
    private List<Agent> _agents = new();
    private List<Team> _teams = new();
    private List<CronJob> _cronJobs = new();
    private List<Trigger> _triggers = new();
    private List<CronJobLog> _cronJobLogs = new();
    private List<TriggerLog> _triggerLogs = new();
    private List<TimeZoneInfo> _timezones = TimeZoneInfo.GetSystemTimeZones().ToList();

    private int _selectedGroupId;
    private string _activeTab = "cron";
    private bool _loading = true;
    private bool _saving = false;

    // Panel state
    private bool _cronPanelOpen = false;
    private bool _triggerPanelOpen = false;
    private CronJob? _editingCronJob = null;
    private Trigger? _editingTrigger = null;

    // Form models
    private CronJobForm _cronForm = new();
    private TriggerForm _triggerForm = new();

    // Selected days for weekly schedule
    private HashSet<int> _selectedDays = new();

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _groups = await db.Groups.OrderBy(g => g.Name).ToListAsync();

        if (_groups.Count > 0)
        {
            _selectedGroupId = GroupId ?? _groups.First().Id;
            await LoadData();
        }
        else
        {
            _loading = false;
        }
    }

    private async Task LoadData()
    {
        _loading = true;

        await using var db = await DbFactory.CreateDbContextAsync();

        _agents = await db.Agents
            .Where(a => a.GroupId == _selectedGroupId)
            .OrderBy(a => a.Name)
            .ToListAsync();

        _teams = await db.Teams
            .Where(t => t.GroupId == _selectedGroupId)
            .OrderBy(t => t.Name)
            .ToListAsync();

        _cronJobs = await CronJobService.GetJobsByGroupAsync(_selectedGroupId);
        _triggers = await TriggerService.GetTriggersByGroupAsync(_selectedGroupId);

        // Load recent logs
        _cronJobLogs = await CronJobService.GetRecentLogsAsync(_selectedGroupId, 50);
        _triggerLogs = await TriggerService.GetRecentLogsAsync(_selectedGroupId, 50);

        _loading = false;
    }

    private void SwitchTab(string tab)
    {
        _activeTab = tab;
    }

    private void SwitchToCron() => _activeTab = "cron";
    private void SwitchToTriggers() => _activeTab = "triggers";
    private void SwitchToLogs() => _activeTab = "logs";
    private void GoToGroups() => NavigationManager.NavigateTo("/groups");

    private void OpenCreatePanel()
    {
        if (_activeTab == "cron")
        {
            _editingCronJob = null;
            _cronForm = new CronJobForm();
            _selectedDays.Clear();
            _cronPanelOpen = true;
        }
        else if (_activeTab == "triggers")
        {
            _editingTrigger = null;
            _triggerForm = new TriggerForm();
            _triggerPanelOpen = true;
        }
    }

    private void OpenEditCronJob(CronJob job)
    {
        _editingCronJob = job;
        _cronForm = new CronJobForm
        {
            Name = job.Name,
            Description = job.Description ?? "",
            ScheduleType = job.ScheduleType,
            CronExpression = job.CronExpression ?? "",
            IntervalMinutes = job.IntervalMinutes ?? 15,
            TimeOfDay = job.TimeOfDay ?? "09:00",
            DayOfMonth = job.DayOfMonth ?? 1,
            Timezone = job.Timezone,
            ActionType = job.ActionType,
            TargetAgentId = job.TargetAgentId?.ToString() ?? "",
            TargetTeamId = job.TargetTeamId?.ToString() ?? "",
            MessageTemplate = job.MessageTemplate,
            SkipIfAgentOffline = job.SkipIfAgentOffline,
            RetryOnFailure = job.RetryOnFailure
        };

        // Parse days of week
        _selectedDays.Clear();
        if (!string.IsNullOrEmpty(job.DaysOfWeek))
        {
            foreach (var day in job.DaysOfWeek.Split(','))
            {
                if (int.TryParse(day.Trim(), out var d))
                    _selectedDays.Add(d);
            }
        }

        _cronPanelOpen = true;
    }

    private void OpenEditTrigger(Trigger trigger)
    {
        _editingTrigger = trigger;
        _triggerForm = new TriggerForm
        {
            Name = trigger.Name,
            Description = trigger.Description ?? "",
            EventType = trigger.EventType,
            SourceAgentId = trigger.SourceAgentId?.ToString() ?? "",
            ActionType = trigger.ActionType,
            TargetAgentId = trigger.TargetAgentId?.ToString() ?? "",
            TargetTeamId = trigger.TargetTeamId?.ToString() ?? "",
            MessageTemplate = trigger.MessageTemplate,
            DelaySeconds = trigger.DelaySeconds,
            CooldownSeconds = trigger.CooldownSeconds
        };
        _triggerPanelOpen = true;
    }

    private void ClosePanel()
    {
        _cronPanelOpen = false;
        _triggerPanelOpen = false;
        _editingCronJob = null;
        _editingTrigger = null;
    }

    private async Task SaveCronJob()
    {
        if (string.IsNullOrWhiteSpace(_cronForm.Name)) return;

        _saving = true;

        try
        {
            if (_editingCronJob != null)
            {
                await CronJobService.UpdateJobAsync(_editingCronJob.Id, job =>
                {
                    ApplyCronForm(job);
                });
            }
            else
            {
                var job = new CronJob { GroupId = _selectedGroupId };
                ApplyCronForm(job);
                await CronJobService.CreateJobAsync(job);
            }

            await LoadData();
            ClosePanel();
        }
        finally
        {
            _saving = false;
        }
    }

    private void ApplyCronForm(CronJob job)
    {
        job.Name = _cronForm.Name;
        job.Description = string.IsNullOrWhiteSpace(_cronForm.Description) ? null : _cronForm.Description;
        job.ScheduleType = _cronForm.ScheduleType;
        job.ActionType = _cronForm.ActionType;
        job.MessageTemplate = _cronForm.MessageTemplate;
        job.SkipIfAgentOffline = _cronForm.SkipIfAgentOffline;
        job.RetryOnFailure = _cronForm.RetryOnFailure;
        job.Timezone = _cronForm.Timezone;

        // Schedule-specific fields
        job.CronExpression = _cronForm.ScheduleType == ScheduleType.Cron ? _cronForm.CronExpression : null;
        job.IntervalMinutes = _cronForm.ScheduleType == ScheduleType.Interval ? _cronForm.IntervalMinutes : null;
        job.TimeOfDay = _cronForm.ScheduleType == ScheduleType.Daily ||
                        _cronForm.ScheduleType == ScheduleType.Weekly ||
                        _cronForm.ScheduleType == ScheduleType.Monthly
            ? _cronForm.TimeOfDay : null;
        job.DaysOfWeek = _cronForm.ScheduleType == ScheduleType.Weekly && _selectedDays.Count > 0
            ? string.Join(",", _selectedDays.OrderBy(d => d)) : null;
        job.DayOfMonth = _cronForm.ScheduleType == ScheduleType.Monthly ? _cronForm.DayOfMonth : null;

        if (_cronForm.ScheduleType == ScheduleType.OneTime && _cronForm.OneTimeDate.HasValue)
        {
            // Convert from local time input to UTC using the selected timezone
            try
            {
                var tz = TimeZoneInfo.FindSystemTimeZoneById(_cronForm.Timezone);
                job.NextRunAt = TimeZoneInfo.ConvertTimeToUtc(_cronForm.OneTimeDate.Value, tz);
            }
            catch
            {
                job.NextRunAt = _cronForm.OneTimeDate.Value.ToUniversalTime();
            }
        }

        // Target fields
        job.TargetAgentId = int.TryParse(_cronForm.TargetAgentId, out var agentId) ? agentId : null;
        job.TargetTeamId = int.TryParse(_cronForm.TargetTeamId, out var teamId) ? teamId : null;
    }

    private async Task DeleteCronJob()
    {
        if (_editingCronJob == null) return;

        await CronJobService.DeleteJobAsync(_editingCronJob.Id);
        await LoadData();
        ClosePanel();
    }

    private async Task ToggleCronJob(CronJob job)
    {
        await CronJobService.ToggleJobAsync(job.Id, !job.Enabled);
        job.Enabled = !job.Enabled;
    }

    private async Task SaveTrigger()
    {
        if (string.IsNullOrWhiteSpace(_triggerForm.Name)) return;

        _saving = true;

        try
        {
            if (_editingTrigger != null)
            {
                await TriggerService.UpdateTriggerAsync(_editingTrigger.Id, trigger =>
                {
                    ApplyTriggerForm(trigger);
                });
            }
            else
            {
                var trigger = new Trigger { GroupId = _selectedGroupId };
                ApplyTriggerForm(trigger);
                await TriggerService.CreateTriggerAsync(trigger);
            }

            await LoadData();
            ClosePanel();
        }
        finally
        {
            _saving = false;
        }
    }

    private void ApplyTriggerForm(Trigger trigger)
    {
        trigger.Name = _triggerForm.Name;
        trigger.Description = string.IsNullOrWhiteSpace(_triggerForm.Description) ? null : _triggerForm.Description;
        trigger.EventType = _triggerForm.EventType;
        trigger.ActionType = _triggerForm.ActionType;
        trigger.MessageTemplate = _triggerForm.MessageTemplate;
        trigger.DelaySeconds = _triggerForm.DelaySeconds;
        trigger.CooldownSeconds = _triggerForm.CooldownSeconds;
        trigger.SourceAgentId = int.TryParse(_triggerForm.SourceAgentId, out var sourceAgentId) ? sourceAgentId : null;
        trigger.TargetAgentId = int.TryParse(_triggerForm.TargetAgentId, out var targetAgentId) ? targetAgentId : null;
        trigger.TargetTeamId = int.TryParse(_triggerForm.TargetTeamId, out var targetTeamId) ? targetTeamId : null;
    }

    private async Task DeleteTrigger()
    {
        if (_editingTrigger == null) return;

        await TriggerService.DeleteTriggerAsync(_editingTrigger.Id);
        await LoadData();
        ClosePanel();
    }

    private async Task ToggleTrigger(Trigger trigger)
    {
        await TriggerService.ToggleTriggerAsync(trigger.Id, !trigger.Enabled);
        trigger.Enabled = !trigger.Enabled;
    }

    private bool IsDaySelected(int day) => _selectedDays.Contains(day);

    private void ToggleDay(int day)
    {
        if (_selectedDays.Contains(day))
            _selectedDays.Remove(day);
        else
            _selectedDays.Add(day);
    }

    private string GetScheduleTypeName(ScheduleType type) => type switch
    {
        ScheduleType.Cron => "Cron",
        ScheduleType.Interval => "Interval",
        ScheduleType.Daily => "Daily",
        ScheduleType.Weekly => "Weekly",
        ScheduleType.Monthly => "Monthly",
        ScheduleType.OneTime => "One-Time",
        _ => type.ToString()
    };

    private string GetActionTarget(CronJob job)
    {
        if (job.TargetAgent != null) return $"Agent: {job.TargetAgent.Name}";
        if (job.TargetTeam != null) return $"Team: {job.TargetTeam.Name}";
        return job.ActionType.ToString();
    }

    private string GetTriggerTarget(Trigger trigger)
    {
        if (trigger.TargetAgent != null) return $"Agent: {trigger.TargetAgent.Name}";
        if (trigger.TargetTeam != null) return $"Team: {trigger.TargetTeam.Name}";
        return trigger.ActionType.ToString();
    }

    private string GetRelativeTime(DateTime utcTime)
    {
        var diff = DateTime.UtcNow - utcTime;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        return $"{(int)diff.TotalDays}d ago";
    }

    private IEnumerable<LogEntry> GetCombinedLogs()
    {
        var cronLogs = _cronJobLogs.Select(l => new LogEntry
        {
            IsCronJob = true,
            ExecutedAt = l.StartedAt,
            Name = l.CronJob?.Name ?? "Unknown",
            Target = l.Target ?? "-",
            Status = l.Status,
            DurationMs = l.DurationMs
        });

        var triggerLogs = _triggerLogs.Select(l => new LogEntry
        {
            IsCronJob = false,
            ExecutedAt = l.ExecutedAt,
            Name = l.Trigger?.Name ?? "Unknown",
            Target = l.Target ?? "-",
            Status = l.Status,
            DurationMs = null
        });

        return cronLogs.Concat(triggerLogs).OrderByDescending(l => l.ExecutedAt).Take(100);
    }

    // Form models
    private class CronJobForm
    {
        public string Name { get; set; } = "";
        public string Description { get; set; } = "";
        public ScheduleType ScheduleType { get; set; } = ScheduleType.Daily;
        public string CronExpression { get; set; } = "";
        public int IntervalMinutes { get; set; } = 15;
        public string TimeOfDay { get; set; } = "09:00";
        public int DayOfMonth { get; set; } = 1;
        public DateTime? OneTimeDate { get; set; }
        public string Timezone { get; set; } = TimeZoneInfo.Local.Id;
        public JobActionType ActionType { get; set; } = JobActionType.PromptAgent;
        public string TargetAgentId { get; set; } = "";
        public string TargetTeamId { get; set; } = "";
        public string MessageTemplate { get; set; } = "";
        public bool SkipIfAgentOffline { get; set; } = false;
        public bool RetryOnFailure { get; set; } = false;
    }

    private class TriggerForm
    {
        public string Name { get; set; } = "";
        public string Description { get; set; } = "";
        public TriggerEventType EventType { get; set; } = TriggerEventType.AgentOnline;
        public string SourceAgentId { get; set; } = "";
        public JobActionType ActionType { get; set; } = JobActionType.PromptAgent;
        public string TargetAgentId { get; set; } = "";
        public string TargetTeamId { get; set; } = "";
        public string MessageTemplate { get; set; } = "";
        public int DelaySeconds { get; set; } = 0;
        public int CooldownSeconds { get; set; } = 0;
    }

    private class LogEntry
    {
        public bool IsCronJob { get; set; }
        public DateTime ExecutedAt { get; set; }
        public string Name { get; set; } = "";
        public string Target { get; set; } = "";
        public JobExecutionStatus Status { get; set; }
        public long? DurationMs { get; set; }
    }

    /// <summary>
    /// Format a UTC datetime using the job's timezone
    /// </summary>
    private string FormatInJobTimezone(DateTime utcTime, string timezone)
    {
        try
        {
            var tz = TimeZoneInfo.FindSystemTimeZoneById(timezone);
            var localTime = TimeZoneInfo.ConvertTimeFromUtc(utcTime, tz);
            return localTime.ToString("MMM d, HH:mm");
        }
        catch
        {
            // Fallback to local time if timezone is invalid
            return utcTime.ToLocalTime().ToString("MMM d, HH:mm");
        }
    }

    /// <summary>
    /// Format a UTC datetime to local time for logs
    /// </summary>
    private string FormatUtcToLocal(DateTime utcTime)
    {
        return utcTime.ToLocalTime().ToString("MMM d, HH:mm:ss");
    }
}
