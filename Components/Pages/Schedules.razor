@page "/schedules"
@page "/schedules/{GroupId:int}"
@using AgentCompanyWeb.Data
@using AgentCompanyWeb.Data.Models
@using AgentCompanyWeb.Services
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@inject CronJobService CronJobService
@inject TriggerService TriggerService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Schedules - Agent Company</PageTitle>

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Schedules</h1>
        @if (_groups.Count > 0)
        {
            <select class="form-select group-select" @bind="_selectedGroupId" @bind:after="LoadData">
                @foreach (var group in _groups)
                {
                    <option value="@group.Id">@group.Name</option>
                }
            </select>
        }
    </div>
    <div class="page-actions">
        <button class="btn btn-primary" @onclick="OpenCreatePanel">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            @(_activeTab == "cron" ? "New Cron Job" : "New Trigger")
        </button>
    </div>
</div>

<div class="page-body">
    <!-- Tabs -->
    <div class="tab-bar">
        <button class="tab-item @(_activeTab == "cron" ? "active" : "")" @onclick="SwitchToCron">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
            Cron Jobs
            <span class="tab-badge">@_cronJobs.Count</span>
        </button>
        <button class="tab-item @(_activeTab == "triggers" ? "active" : "")" @onclick="SwitchToTriggers">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
            </svg>
            Triggers
            <span class="tab-badge">@_triggers.Count</span>
        </button>
        <button class="tab-item @(_activeTab == "logs" ? "active" : "")" @onclick="SwitchToLogs">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
                <line x1="16" y1="13" x2="8" y2="13"></line>
                <line x1="16" y1="17" x2="8" y2="17"></line>
            </svg>
            Execution Logs
        </button>
    </div>

    @if (_loading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <span>Loading schedules...</span>
        </div>
    }
    else if (_groups.Count == 0)
    {
        <div class="empty-state">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
            </svg>
            <div class="empty-state-title">No groups yet</div>
            <div class="empty-state-text">Create a group first to add scheduled jobs.</div>
            <button class="btn btn-primary mt-4" @onclick="GoToGroups">Go to Groups</button>
        </div>
    }
    else if (_activeTab == "cron")
    {
        @if (_cronJobs.Count == 0)
        {
            <div class="empty-state">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
                <div class="empty-state-title">No cron jobs</div>
                <div class="empty-state-text">Schedule recurring tasks to prompt agents or send messages automatically.</div>
                <button class="btn btn-primary mt-4" @onclick="OpenCreatePanel">Create Cron Job</button>
            </div>
        }
        else
        {
            <div class="schedule-list">
                @foreach (var job in _cronJobs)
                {
                    <div class="schedule-card @(job.Enabled ? "" : "disabled")" @onclick="() => OpenEditCronJob(job)">
                        <div class="schedule-card-header">
                            <div class="schedule-card-title">
                                <span class="schedule-name">@job.Name</span>
                                <span class="schedule-type-badge">@GetScheduleTypeName(job.ScheduleType)</span>
                            </div>
                            <label class="toggle" @onclick:stopPropagation="true">
                                <input type="checkbox" checked="@job.Enabled" @onchange="() => ToggleCronJob(job)" />
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                        <div class="schedule-card-body">
                            <div class="schedule-detail">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <polyline points="12 6 12 12 16 14"></polyline>
                                </svg>
                                <span>@CronExpressionParser.GetScheduleDescription(job)</span>
                            </div>
                            <div class="schedule-detail">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="12" cy="7" r="4"></circle>
                                </svg>
                                <span>@GetActionTarget(job)</span>
                            </div>
                            @if (job.NextRunAt.HasValue)
                            {
                                <div class="schedule-detail">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="23 4 23 10 17 10"></polyline>
                                        <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
                                    </svg>
                                    <span>Next: @FormatInJobTimezone(job.NextRunAt.Value, job.Timezone)</span>
                                </div>
                            }
                        </div>
                        <div class="schedule-card-footer">
                            <span class="schedule-stat">
                                @job.ExecutionCount executions
                            </span>
                            @if (job.LastRunAt.HasValue)
                            {
                                <span class="schedule-stat @(job.LastRunStatus == JobExecutionStatus.Success ? "success" : job.LastRunStatus == JobExecutionStatus.Failed ? "error" : "")">
                                    Last: @GetRelativeTime(job.LastRunAt.Value)
                                </span>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    }
    else if (_activeTab == "triggers")
    {
        @if (_triggers.Count == 0)
        {
            <div class="empty-state">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                </svg>
                <div class="empty-state-title">No triggers</div>
                <div class="empty-state-text">Create event-based triggers to automatically respond to agent status changes, messages, and more.</div>
                <button class="btn btn-primary mt-4" @onclick="OpenCreatePanel">Create Trigger</button>
            </div>
        }
        else
        {
            <div class="schedule-list">
                @foreach (var trigger in _triggers)
                {
                    <div class="schedule-card @(trigger.Enabled ? "" : "disabled")" @onclick="() => OpenEditTrigger(trigger)">
                        <div class="schedule-card-header">
                            <div class="schedule-card-title">
                                <span class="schedule-name">@trigger.Name</span>
                                <span class="schedule-type-badge trigger">@trigger.EventType</span>
                            </div>
                            <label class="toggle" @onclick:stopPropagation="true">
                                <input type="checkbox" checked="@trigger.Enabled" @onchange="() => ToggleTrigger(trigger)" />
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                        <div class="schedule-card-body">
                            <div class="schedule-detail">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                                </svg>
                                <span>@TriggerService.GetEventTypeDescription(trigger.EventType)</span>
                            </div>
                            <div class="schedule-detail">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="12" cy="7" r="4"></circle>
                                </svg>
                                <span>@GetTriggerTarget(trigger)</span>
                            </div>
                        </div>
                        <div class="schedule-card-footer">
                            <span class="schedule-stat">
                                @trigger.TriggerCount triggers
                            </span>
                            @if (trigger.LastTriggeredAt.HasValue)
                            {
                                <span class="schedule-stat">
                                    Last: @GetRelativeTime(trigger.LastTriggeredAt.Value)
                                </span>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    }
    else if (_activeTab == "logs")
    {
        <div class="log-list">
            @if (_cronJobLogs.Count == 0 && _triggerLogs.Count == 0)
            {
                <div class="empty-state">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                    </svg>
                    <div class="empty-state-title">No execution logs</div>
                    <div class="empty-state-text">Logs will appear here when cron jobs or triggers execute.</div>
                </div>
            }
            else
            {
                <table class="log-table">
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Type</th>
                            <th>Name</th>
                            <th>Target</th>
                            <th>Status</th>
                            <th>Duration</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in GetCombinedLogs())
                        {
                            <tr class="@(log.Status == JobExecutionStatus.Failed ? "error" : log.Status == JobExecutionStatus.Skipped ? "skipped" : "")">
                                <td>@FormatUtcToLocal(log.ExecutedAt)</td>
                                <td><span class="log-type-badge @(log.IsCronJob ? "cron" : "trigger")">@(log.IsCronJob ? "Cron" : "Trigger")</span></td>
                                <td>@log.Name</td>
                                <td>@log.Target</td>
                                <td>
                                    <span class="status-badge @log.Status.ToString().ToLower()">
                                        @log.Status
                                    </span>
                                </td>
                                <td>@(log.DurationMs.HasValue ? $"{log.DurationMs}ms" : "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
</div>

<!-- Cron Job Panel -->
<div class="modal-overlay @(_cronPanelOpen ? "active" : "")" @onclick="ClosePanel"></div>
<div class="slide-panel @(_cronPanelOpen ? "active" : "")">
    <div class="slide-panel-header">
        <span class="slide-panel-title">@(_editingCronJob != null ? "Edit Cron Job" : "New Cron Job")</span>
        <button class="btn btn-ghost btn-icon" @onclick="ClosePanel">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>
    </div>
    <div class="slide-panel-body">
        <div class="form-group">
            <label class="form-label">Name</label>
            <input type="text" class="form-input" placeholder="e.g., Daily Standup Reminder" @bind="_cronForm.Name" />
        </div>
        <div class="form-group">
            <label class="form-label">Description</label>
            <input type="text" class="form-input" placeholder="Optional description" @bind="_cronForm.Description" />
        </div>

        <div class="form-divider"></div>

        <div class="form-group">
            <label class="form-label">Schedule Type</label>
            <select class="form-select" @bind="_cronForm.ScheduleType">
                <option value="@ScheduleType.Interval">Interval (every X minutes)</option>
                <option value="@ScheduleType.Daily">Daily</option>
                <option value="@ScheduleType.Weekly">Weekly</option>
                <option value="@ScheduleType.Monthly">Monthly</option>
                <option value="@ScheduleType.Cron">Cron Expression</option>
                <option value="@ScheduleType.OneTime">One-Time</option>
            </select>
        </div>

        @if (_cronForm.ScheduleType == ScheduleType.Interval)
        {
            <div class="form-group">
                <label class="form-label">Run Every (minutes)</label>
                <input type="number" class="form-input" min="1" max="1440" @bind="_cronForm.IntervalMinutes" />
            </div>
        }
        else if (_cronForm.ScheduleType == ScheduleType.Daily)
        {
            <div class="form-group">
                <label class="form-label">Time (HH:mm)</label>
                <input type="text" class="form-input" placeholder="09:00" @bind="_cronForm.TimeOfDay" />
            </div>
        }
        else if (_cronForm.ScheduleType == ScheduleType.Weekly)
        {
            <div class="form-group">
                <label class="form-label">Time (HH:mm)</label>
                <input type="text" class="form-input" placeholder="09:00" @bind="_cronForm.TimeOfDay" />
            </div>
            <div class="form-group">
                <label class="form-label">Days</label>
                <div class="day-picker">
                    @for (int i = 0; i < 7; i++)
                    {
                        var dayIndex = i;
                        var dayName = new[] { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" }[i];
                        <label class="day-option">
                            <input type="checkbox" checked="@IsDaySelected(dayIndex)" @onchange="@(() => ToggleDay(dayIndex))" />
                            <span>@dayName</span>
                        </label>
                    }
                </div>
            </div>
        }
        else if (_cronForm.ScheduleType == ScheduleType.Monthly)
        {
            <div class="form-group">
                <label class="form-label">Day of Month</label>
                <input type="number" class="form-input" min="1" max="31" @bind="_cronForm.DayOfMonth" />
                <span class="form-hint">Use 0 for last day of month</span>
            </div>
            <div class="form-group">
                <label class="form-label">Time (HH:mm)</label>
                <input type="text" class="form-input" placeholder="09:00" @bind="_cronForm.TimeOfDay" />
            </div>
        }
        else if (_cronForm.ScheduleType == ScheduleType.Cron)
        {
            <div class="form-group">
                <label class="form-label">Cron Expression</label>
                <input type="text" class="form-input" placeholder="*/15 * * * *" @bind="_cronForm.CronExpression" />
                <span class="form-hint">Format: minute hour day-of-month month day-of-week</span>
            </div>
        }
        else if (_cronForm.ScheduleType == ScheduleType.OneTime)
        {
            <div class="form-group">
                <label class="form-label">Date & Time</label>
                <input type="datetime-local" class="form-input" @bind="_cronForm.OneTimeDate" />
            </div>
        }

        <div class="form-group">
            <label class="form-label">Timezone</label>
            <select class="form-select" @bind="_cronForm.Timezone">
                @foreach (var tz in _timezones)
                {
                    <option value="@tz.Id">@tz.DisplayName</option>
                }
            </select>
        </div>

        <div class="form-divider"></div>

        <div class="form-group">
            <label class="form-label">Action</label>
            <select class="form-select" @bind="_cronForm.ActionType">
                <option value="@JobActionType.PromptAgent">Prompt Agent</option>
                <option value="@JobActionType.SendDirectMessage">Send Direct Message</option>
                <option value="@JobActionType.SendTeamMessage">Send Team Message</option>
                <option value="@JobActionType.StartAgent">Start Agent</option>
                <option value="@JobActionType.StopAgent">Stop Agent</option>
                <option value="@JobActionType.RestartAgent">Restart Agent</option>
            </select>
        </div>

        @if (_cronForm.ActionType == JobActionType.PromptAgent || _cronForm.ActionType == JobActionType.SendDirectMessage ||
             _cronForm.ActionType == JobActionType.StartAgent || _cronForm.ActionType == JobActionType.StopAgent ||
             _cronForm.ActionType == JobActionType.RestartAgent)
        {
            <div class="form-group">
                <label class="form-label">Target Agent</label>
                <select class="form-select" @bind="_cronForm.TargetAgentId">
                    <option value="">Select an agent...</option>
                    @foreach (var agent in _agents)
                    {
                        <option value="@agent.Id">@agent.Name</option>
                    }
                </select>
            </div>
        }

        @if (_cronForm.ActionType == JobActionType.SendTeamMessage)
        {
            <div class="form-group">
                <label class="form-label">Target Team</label>
                <select class="form-select" @bind="_cronForm.TargetTeamId">
                    <option value="">Select a team...</option>
                    @foreach (var team in _teams)
                    {
                        <option value="@team.Id">@team.Name</option>
                    }
                </select>
            </div>
        }

        @if (_cronForm.ActionType == JobActionType.PromptAgent || _cronForm.ActionType == JobActionType.SendDirectMessage ||
             _cronForm.ActionType == JobActionType.SendTeamMessage)
        {
            <div class="form-group">
                <label class="form-label">Message</label>
                <textarea class="form-textarea" rows="4" placeholder="Enter the message or prompt..." @bind="_cronForm.MessageTemplate"></textarea>
                <span class="form-hint">Variables: {date}, {time}, {agent_name}, {team_name}, {group_name}</span>
            </div>
        }

        <div class="form-divider"></div>

        <div class="form-group">
            <label class="form-label">Options</label>
            <label class="checkbox-label">
                <input type="checkbox" @bind="_cronForm.SkipIfAgentOffline" />
                Skip if target agent is offline
            </label>
            <label class="checkbox-label">
                <input type="checkbox" @bind="_cronForm.RetryOnFailure" />
                Retry on failure
            </label>
        </div>
    </div>
    <div class="slide-panel-footer">
        @if (_editingCronJob != null)
        {
            <button class="btn btn-ghost danger" @onclick="DeleteCronJob">Delete</button>
        }
        <button class="btn btn-secondary" @onclick="ClosePanel">Cancel</button>
        <button class="btn btn-primary" @onclick="SaveCronJob" disabled="@_saving">
            @(_saving ? "Saving..." : "Save")
        </button>
    </div>
</div>

<!-- Trigger Panel -->
<div class="modal-overlay @(_triggerPanelOpen ? "active" : "")" @onclick="ClosePanel"></div>
<div class="slide-panel @(_triggerPanelOpen ? "active" : "")">
    <div class="slide-panel-header">
        <span class="slide-panel-title">@(_editingTrigger != null ? "Edit Trigger" : "New Trigger")</span>
        <button class="btn btn-ghost btn-icon" @onclick="ClosePanel">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>
    </div>
    <div class="slide-panel-body">
        <div class="form-group">
            <label class="form-label">Name</label>
            <input type="text" class="form-input" placeholder="e.g., Notify on Agent Error" @bind="_triggerForm.Name" />
        </div>
        <div class="form-group">
            <label class="form-label">Description</label>
            <input type="text" class="form-input" placeholder="Optional description" @bind="_triggerForm.Description" />
        </div>

        <div class="form-divider"></div>

        <div class="form-group">
            <label class="form-label">Trigger When</label>
            <select class="form-select" @bind="_triggerForm.EventType">
                <option value="@TriggerEventType.AgentOnline">Agent comes online</option>
                <option value="@TriggerEventType.AgentOffline">Agent goes offline</option>
                <option value="@TriggerEventType.AgentStartedWorking">Agent starts working</option>
                <option value="@TriggerEventType.AgentFinishedWorking">Agent finishes working</option>
                <option value="@TriggerEventType.AgentStatusChanged">Agent status changes</option>
                <option value="@TriggerEventType.AgentTaskChanged">Agent task changes</option>
                <option value="@TriggerEventType.AgentError">Agent error occurs</option>
                <option value="@TriggerEventType.DirectMessageReceived">Direct message received</option>
                <option value="@TriggerEventType.TeamMessageReceived">Team message received</option>
                <option value="@TriggerEventType.FileCreated">File created</option>
                <option value="@TriggerEventType.FileModified">File modified</option>
            </select>
        </div>

        <div class="form-group">
            <label class="form-label">From Agent (optional)</label>
            <select class="form-select" @bind="_triggerForm.SourceAgentId">
                <option value="">Any agent in group</option>
                @foreach (var agent in _agents)
                {
                    <option value="@agent.Id">@agent.Name</option>
                }
            </select>
        </div>

        <div class="form-divider"></div>

        <div class="form-group">
            <label class="form-label">Action</label>
            <select class="form-select" @bind="_triggerForm.ActionType">
                <option value="@JobActionType.PromptAgent">Prompt Agent</option>
                <option value="@JobActionType.SendDirectMessage">Send Direct Message</option>
                <option value="@JobActionType.SendTeamMessage">Send Team Message</option>
            </select>
        </div>

        @if (_triggerForm.ActionType == JobActionType.PromptAgent || _triggerForm.ActionType == JobActionType.SendDirectMessage)
        {
            <div class="form-group">
                <label class="form-label">Target Agent</label>
                <select class="form-select" @bind="_triggerForm.TargetAgentId">
                    <option value="">Select an agent...</option>
                    @foreach (var agent in _agents)
                    {
                        <option value="@agent.Id">@agent.Name</option>
                    }
                </select>
            </div>
        }

        @if (_triggerForm.ActionType == JobActionType.SendTeamMessage)
        {
            <div class="form-group">
                <label class="form-label">Target Team</label>
                <select class="form-select" @bind="_triggerForm.TargetTeamId">
                    <option value="">Select a team...</option>
                    @foreach (var team in _teams)
                    {
                        <option value="@team.Id">@team.Name</option>
                    }
                </select>
            </div>
        }

        <div class="form-group">
            <label class="form-label">Message</label>
            <textarea class="form-textarea" rows="4" placeholder="Enter the message..." @bind="_triggerForm.MessageTemplate"></textarea>
            <span class="form-hint">Variables: {event_type}, {agent_name}, {status}, {error}, {message}</span>
        </div>

        <div class="form-divider"></div>

        <div class="form-group">
            <label class="form-label">Delay (seconds)</label>
            <input type="number" class="form-input" min="0" @bind="_triggerForm.DelaySeconds" />
            <span class="form-hint">Wait before executing action</span>
        </div>
        <div class="form-group">
            <label class="form-label">Cooldown (seconds)</label>
            <input type="number" class="form-input" min="0" @bind="_triggerForm.CooldownSeconds" />
            <span class="form-hint">Minimum time between triggers</span>
        </div>
    </div>
    <div class="slide-panel-footer">
        @if (_editingTrigger != null)
        {
            <button class="btn btn-ghost danger" @onclick="DeleteTrigger">Delete</button>
        }
        <button class="btn btn-secondary" @onclick="ClosePanel">Cancel</button>
        <button class="btn btn-primary" @onclick="SaveTrigger" disabled="@_saving">
            @(_saving ? "Saving..." : "Save")
        </button>
    </div>
</div>

<style>
