@using AgentCompanyWeb.Data
@using AgentCompanyWeb.Data.Models
@using AgentCompanyWeb.Services
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ToastService Toast
@inject NavigationManager Nav

<div class="quick-assign-bar">
    <div class="assign-select-wrapper">
        <button class="assign-select-btn" @onclick="ToggleDropdown">
            @if (_selectedAgents.Count == 0)
            {
                <span class="assign-placeholder">Select Agent(s)</span>
            }
            else if (_selectedAgents.Count == 1)
            {
                <span>@_selectedAgents[0].Name</span>
            }
            else
            {
                <span>@_selectedAgents.Count agents selected</span>
            }
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
        </button>

        @if (_showDropdown)
        {
            <div class="assign-dropdown">
                <div class="dropdown-header">
                    <input type="text" class="dropdown-search" placeholder="Search agents..."
                           @bind="_searchTerm" @bind:event="oninput" />
                </div>
                <div class="dropdown-list">
                    @foreach (var agent in FilteredAgents)
                    {
                        var isSelected = _selectedAgents.Any(a => a.Id == agent.Id);
                        <label class="dropdown-item @(isSelected ? "selected" : "")">
                            <input type="checkbox" checked="@isSelected" @onchange="e => ToggleAgent(agent, (bool)(e.Value ?? false))" />
                            <span class="status-dot @GetStatusClass(agent.Status)"></span>
                            <span class="agent-name">@agent.Name</span>
                            @if (!string.IsNullOrEmpty(agent.Role))
                            {
                                <span class="agent-role">@agent.Role</span>
                            }
                        </label>
                    }
                    @if (!FilteredAgents.Any())
                    {
                        <div class="dropdown-empty">No agents found</div>
                    }
                </div>
                @if (_selectedAgents.Count > 0)
                {
                    <div class="dropdown-footer">
                        <button class="btn-clear" @onclick="ClearSelection">Clear</button>
                    </div>
                }
            </div>
            <div class="dropdown-backdrop" @onclick="() => _showDropdown = false"></div>
        }
    </div>

    <div class="assign-input-wrapper">
        <input type="text" class="assign-input" placeholder="Type task description..."
               @bind="_taskDescription" @bind:event="oninput"
               @onkeydown="HandleKeyDown" />
    </div>

    <button class="assign-send-btn" @onclick="SendTask" disabled="@(!CanSend)">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="22" y1="2" x2="11" y2="13"></line>
            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
    </button>
</div>

<style>
    .quick-assign-bar {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 16px 20px;
        background: var(--bg-card);
        border-radius: var(--radius-lg);
        border: 1px solid var(--border-light);
        box-shadow: var(--shadow-sm);
    }

    .assign-select-wrapper {
        position: relative;
        flex-shrink: 0;
    }

    .assign-select-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 14px;
        background: var(--bg-hover);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        font-size: 13px;
        font-weight: 500;
        color: var(--text-primary);
        cursor: pointer;
        transition: all 0.15s ease;
        min-width: 160px;
    }

    .assign-select-btn:hover {
        border-color: var(--accent);
    }

    .assign-placeholder {
        color: var(--text-tertiary);
    }

    .assign-dropdown {
        position: absolute;
        top: calc(100% + 4px);
        left: 0;
        width: 280px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-lg);
        z-index: 100;
        overflow: hidden;
    }

    .dropdown-backdrop {
        position: fixed;
        inset: 0;
        z-index: 99;
    }

    .dropdown-header {
        padding: 12px;
        border-bottom: 1px solid var(--border-light);
    }

    .dropdown-search {
        width: 100%;
        padding: 8px 12px;
        background: var(--bg-hover);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        font-size: 13px;
        color: var(--text-primary);
    }

    .dropdown-search:focus {
        outline: none;
        border-color: var(--accent);
    }

    .dropdown-list {
        max-height: 240px;
        overflow-y: auto;
        padding: 8px;
    }

    .dropdown-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 10px;
        border-radius: var(--radius-md);
        cursor: pointer;
        transition: background 0.15s ease;
    }

    .dropdown-item:hover {
        background: var(--bg-hover);
    }

    .dropdown-item.selected {
        background: var(--bg-active);
    }

    .dropdown-item input[type="checkbox"] {
        width: 16px;
        height: 16px;
        accent-color: var(--accent);
    }

    .dropdown-item .agent-name {
        font-size: 13px;
        font-weight: 500;
        color: var(--text-primary);
    }

    .dropdown-item .agent-role {
        margin-left: auto;
        font-size: 11px;
        color: var(--text-tertiary);
    }

    .dropdown-empty {
        padding: 16px;
        text-align: center;
        color: var(--text-tertiary);
        font-size: 13px;
    }

    .dropdown-footer {
        padding: 8px 12px;
        border-top: 1px solid var(--border-light);
        display: flex;
        justify-content: flex-end;
    }

    .btn-clear {
        background: none;
        border: none;
        color: var(--text-secondary);
        font-size: 12px;
        cursor: pointer;
    }

    .btn-clear:hover {
        color: var(--danger);
    }

    .assign-input-wrapper {
        flex: 1;
    }

    .assign-input {
        width: 100%;
        padding: 10px 14px;
        background: var(--bg-hover);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        font-size: 14px;
        color: var(--text-primary);
        transition: all 0.15s ease;
    }

    .assign-input:focus {
        outline: none;
        border-color: var(--accent);
        background: var(--bg-card);
    }

    .assign-input::placeholder {
        color: var(--text-tertiary);
    }

    .assign-send-btn {
        flex-shrink: 0;
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--accent);
        border: none;
        border-radius: var(--radius-md);
        color: white;
        cursor: pointer;
        transition: all 0.15s ease;
    }

    .assign-send-btn:hover:not(:disabled) {
        background: var(--accent-hover);
        transform: translateY(-1px);
    }

    .assign-send-btn:disabled {
        background: var(--text-tertiary);
        cursor: not-allowed;
    }
</style>

@code {
    [Parameter] public EventCallback<(List<Agent> agents, string task)> OnTaskAssigned { get; set; }

    private List<Agent> _agents = new();
    private List<Agent> _selectedAgents = new();
    private string _taskDescription = "";
    private string _searchTerm = "";
    private bool _showDropdown = false;

    private bool CanSend => _selectedAgents.Count > 0 && !string.IsNullOrWhiteSpace(_taskDescription);

    private IEnumerable<Agent> FilteredAgents => string.IsNullOrWhiteSpace(_searchTerm)
        ? _agents.Where(a => a.Status != AgentStatus.Offline)
        : _agents.Where(a => a.Status != AgentStatus.Offline &&
            (a.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
             (a.Role?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)));

    protected override async Task OnInitializedAsync()
    {
        await LoadAgents();
    }

    private async Task LoadAgents()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _agents = await db.Agents.OrderBy(a => a.Name).ToListAsync();
    }

    private void ToggleDropdown()
    {
        _showDropdown = !_showDropdown;
        if (_showDropdown)
        {
            _searchTerm = "";
        }
    }

    private void ToggleAgent(Agent agent, bool isSelected)
    {
        if (isSelected)
        {
            if (!_selectedAgents.Any(a => a.Id == agent.Id))
            {
                _selectedAgents.Add(agent);
            }
        }
        else
        {
            _selectedAgents.RemoveAll(a => a.Id == agent.Id);
        }
    }

    private void ClearSelection()
    {
        _selectedAgents.Clear();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && CanSend)
        {
            await SendTask();
        }
    }

    private async Task SendTask()
    {
        if (!CanSend) return;

        var agents = _selectedAgents.ToList();
        var task = _taskDescription;

        // Clear form
        _selectedAgents.Clear();
        _taskDescription = "";
        _showDropdown = false;

        // Notify parent
        await OnTaskAssigned.InvokeAsync((agents, task));

        // Show toast
        if (agents.Count == 1)
        {
            Toast.Success($"Task assigned to {agents[0].Name}");
        }
        else
        {
            Toast.Success($"Task assigned to {agents.Count} agents");
        }
    }

    private string GetStatusClass(AgentStatus status) => status switch
    {
        AgentStatus.Online => "status-online",
        AgentStatus.Working => "status-working",
        AgentStatus.Error => "status-error",
        _ => "status-offline"
    };
}
