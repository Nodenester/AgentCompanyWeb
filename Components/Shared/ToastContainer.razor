@using AgentCompanyWeb.Services
@inject ToastService ToastService
@implements IDisposable

<div class="toast-container">
    @foreach (var toast in _toasts)
    {
        <div class="toast toast-@toast.Type.ToString().ToLower() @(toast.IsExiting ? "exiting" : "entering")"
             @key="toast.Id">
            <div class="toast-icon">
                @switch (toast.Type)
                {
                    case ToastType.Success:
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                            <polyline points="22 4 12 14.01 9 11.01"></polyline>
                        </svg>
                        break;
                    case ToastType.Warning:
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                            <line x1="12" y1="9" x2="12" y2="13"></line>
                            <line x1="12" y1="17" x2="12.01" y2="17"></line>
                        </svg>
                        break;
                    case ToastType.Error:
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="15" y1="9" x2="9" y2="15"></line>
                            <line x1="9" y1="9" x2="15" y2="15"></line>
                        </svg>
                        break;
                    default:
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="16" x2="12" y2="12"></line>
                            <line x1="12" y1="8" x2="12.01" y2="8"></line>
                        </svg>
                        break;
                }
            </div>
            <div class="toast-content">
                <span class="toast-message">@toast.Message</span>
                @if (!string.IsNullOrEmpty(toast.ActionText))
                {
                    <button class="toast-action" @onclick="() => HandleAction(toast)">
                        @toast.ActionText
                    </button>
                }
            </div>
            <button class="toast-dismiss" @onclick="() => DismissToast(toast.Id)">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
            <div class="toast-progress" style="animation-duration: @(toast.DurationMs)ms;"></div>
        </div>
    }
</div>

@if (_toasts.Count > 2)
{
    <button class="toast-dismiss-all" @onclick="DismissAll">
        Dismiss All (@_toasts.Count)
    </button>
}

<style>
    .toast-container {
        position: fixed;
        bottom: 24px;
        right: 24px;
        display: flex;
        flex-direction: column-reverse;
        gap: 12px;
        z-index: 9999;
        pointer-events: none;
    }

    .toast {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 14px 16px;
        background: var(--bg-card);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-lg);
        border: 1px solid var(--border);
        min-width: 320px;
        max-width: 420px;
        pointer-events: auto;
        position: relative;
        overflow: hidden;
    }

    .toast.entering {
        animation: toastEnter 0.3s ease forwards;
    }

    .toast.exiting {
        animation: toastExit 0.25s ease forwards;
    }

    @@keyframes toastEnter {
        from {
            opacity: 0;
            transform: translateX(100%);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes toastExit {
        from {
            opacity: 1;
            transform: translateX(0);
        }
        to {
            opacity: 0;
            transform: translateX(100%);
        }
    }

    .toast-icon {
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
    }

    .toast-success .toast-icon { color: var(--success); }
    .toast-warning .toast-icon { color: var(--warning); }
    .toast-error .toast-icon { color: var(--danger); }
    .toast-info .toast-icon { color: var(--accent); }

    .toast-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .toast-message {
        font-size: 14px;
        font-weight: 500;
        color: var(--text-primary);
        line-height: 1.4;
    }

    .toast-action {
        background: none;
        border: none;
        padding: 0;
        color: var(--accent);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        align-self: flex-start;
    }

    .toast-action:hover {
        text-decoration: underline;
    }

    .toast-dismiss {
        flex-shrink: 0;
        background: none;
        border: none;
        padding: 4px;
        cursor: pointer;
        color: var(--text-tertiary);
        border-radius: var(--radius-sm);
        transition: all 0.15s ease;
    }

    .toast-dismiss:hover {
        background: var(--bg-hover);
        color: var(--text-primary);
    }

    .toast-progress {
        position: absolute;
        bottom: 0;
        left: 0;
        height: 3px;
        width: 100%;
        background: var(--text-tertiary);
        opacity: 0.3;
        animation: progressShrink linear forwards;
        transform-origin: left;
    }

    .toast-success .toast-progress { background: var(--success); }
    .toast-warning .toast-progress { background: var(--warning); }
    .toast-error .toast-progress { background: var(--danger); }
    .toast-info .toast-progress { background: var(--accent); }

    @@keyframes progressShrink {
        from { transform: scaleX(1); }
        to { transform: scaleX(0); }
    }

    .toast-dismiss-all {
        position: fixed;
        bottom: 24px;
        right: 24px;
        transform: translateY(calc(-100% - 12px));
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-full);
        padding: 8px 16px;
        font-size: 12px;
        font-weight: 500;
        color: var(--text-secondary);
        cursor: pointer;
        box-shadow: var(--shadow-md);
        z-index: 10000;
        transition: all 0.15s ease;
    }

    .toast-dismiss-all:hover {
        background: var(--bg-hover);
        color: var(--text-primary);
    }
</style>

@code {
    private List<ToastState> _toasts = new();

    protected override void OnInitialized()
    {
        ToastService.OnToast += HandleNewToast;
        ToastService.OnDismiss += HandleDismiss;
        ToastService.OnDismissAll += HandleDismissAll;
    }

    private void HandleNewToast(ToastMessage toast)
    {
        InvokeAsync(() =>
        {
            var state = new ToastState(toast);
            _toasts.Add(state);
            StateHasChanged();

            // Auto-dismiss after duration
            _ = AutoDismissAsync(state);
        });
    }

    private async Task AutoDismissAsync(ToastState toast)
    {
        await Task.Delay(toast.DurationMs);
        await DismissToast(toast.Id);
    }

    private async Task DismissToast(Guid id)
    {
        await InvokeAsync(() =>
        {
            var toast = _toasts.FirstOrDefault(t => t.Id == id);
            if (toast != null && !toast.IsExiting)
            {
                toast.IsExiting = true;
                StateHasChanged();

                // Remove after exit animation
                _ = Task.Delay(250).ContinueWith(_ =>
                {
                    InvokeAsync(() =>
                    {
                        _toasts.RemoveAll(t => t.Id == id);
                        ToastService.Dismiss(id);
                        StateHasChanged();
                    });
                });
            }
        });
    }

    private void HandleDismiss(Guid id)
    {
        InvokeAsync(() =>
        {
            _toasts.RemoveAll(t => t.Id == id);
            StateHasChanged();
        });
    }

    private void HandleDismissAll()
    {
        InvokeAsync(() =>
        {
            _toasts.Clear();
            StateHasChanged();
        });
    }

    private void DismissAll()
    {
        foreach (var toast in _toasts.ToList())
        {
            _ = DismissToast(toast.Id);
        }
    }

    private void HandleAction(ToastState toast)
    {
        toast.OnAction?.Invoke();
        _ = DismissToast(toast.Id);
    }

    public void Dispose()
    {
        ToastService.OnToast -= HandleNewToast;
        ToastService.OnDismiss -= HandleDismiss;
        ToastService.OnDismissAll -= HandleDismissAll;
    }

    private class ToastState
    {
        public Guid Id { get; }
        public string Message { get; }
        public ToastType Type { get; }
        public int DurationMs { get; }
        public string? ActionText { get; }
        public Action? OnAction { get; }
        public bool IsExiting { get; set; }

        public ToastState(ToastMessage message)
        {
            Id = message.Id;
            Message = message.Message;
            Type = message.Type;
            DurationMs = message.DurationMs;
            ActionText = message.ActionText;
            OnAction = message.OnAction;
        }
    }
}
